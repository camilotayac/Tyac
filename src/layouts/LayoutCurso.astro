---
// ============================================================
// src/layouts/LayoutCurso.astro — Layout para páginas de clase
// ============================================================
// Este layout se usa SOLO en los archivos .md de las lecciones.
// Construye la estructura de: Sidebar izquierdo + Contenido derecho.
//
// CÓMO SE ACTIVA desde un archivo .md:
//   ---
//   layout: ../../layouts/LayoutCurso.astro
//   curso: conjuntos          ← debe coincidir con una clave en temarios.js
//   id_clase: proposicion     ← debe coincidir con el "id" en temarios.js
//   ---
//
// LO QUE HACE AUTOMÁTICAMENTE:
//   - Busca el curso correcto en temarios.js
//   - Resalta la lección activa en el sidebar
//   - Calcula y muestra los botones "Anterior" y "Siguiente"
//   - Pone el título de la lección en la pestaña del navegador

// Importamos el layout base (header + variables CSS)
import Layout from './Layout.astro';
// Importamos el sidebar (columna izquierda con la lista de lecciones)
import SidebarCurso from '../components/SidebarCurso.astro';
// Importamos los datos de todos los cursos y sus lecciones
import { todosLosTemarios } from '../data/temarios.js';

// "frontmatter" contiene todos los datos del encabezado del archivo .md
const { frontmatter } = Astro.props;

// ID de la lección actual (viene del frontmatter del .md)
// Ejemplo: "proposicion"
const claseActualId = frontmatter.id_clase;

// Tipo TypeScript: garantiza que el nombre del curso sea una clave válida
// de temarios.js (ej: "conjuntos", "dinamica_molecular")
type CursoValido = keyof typeof todosLosTemarios;
const cursoActual = frontmatter.curso as CursoValido;

// Buscamos la lista de lecciones del curso actual en temarios.js
// Si el curso no existe, usamos un array vacío para no romper el sitio
const temarioSeleccionado = (cursoActual && todosLosTemarios[cursoActual])
    ? todosLosTemarios[cursoActual]
    : [];

// Buscamos los datos completos de ESTA lección específica
// (para obtener su título oficial desde temarios.js)
const datosDeEstaClase = temarioSeleccionado.find((clase: any) => clase.id === claseActualId);

// Determinamos el título que se mostrará en el h1 y en la pestaña
// Orden de prioridad: título en temarios.js → título en frontmatter → texto por defecto
const tituloPagina = datosDeEstaClase
    ? datosDeEstaClase.titulo
    : (frontmatter.titulo || "Clase Tyac");

// Calculamos la posición de esta lección dentro del temario (0, 1, 2...)
// Esto nos permite saber cuál viene antes y cuál después
const indiceActual = temarioSeleccionado.findIndex((clase: any) => clase.id === claseActualId);

// Si no es la primera lección, habrá una anterior (indice > 0)
const claseAnterior = indiceActual > 0 ? temarioSeleccionado[indiceActual - 1] : null;

// Si no es la última lección, habrá una siguiente
const claseSiguiente = (indiceActual !== -1 && indiceActual < temarioSeleccionado.length - 1)
    ? temarioSeleccionado[indiceActual + 1]
    : null;
---

<!-- Envolvemos todo en el Layout base para heredar el header y los estilos -->
<Layout titulo={`${tituloPagina} - Tyac`}>

    <!-- Contenedor principal: divide la pantalla en sidebar + contenido -->
    <div class="contenedor-curso">

        <!-- SIDEBAR IZQUIERDO: solo se muestra si el curso tiene lecciones -->
        {temarioSeleccionado.length > 0 && cursoActual && (
            <SidebarCurso
                lecciones={temarioSeleccionado}
                claseActualId={claseActualId}
                cursoActualId={cursoActual}
            />
        )}

        <!-- ÁREA PRINCIPAL: donde se renderiza el contenido de la lección -->
        <main class="area-principal">

            <div class="markdown-container">

                <!-- Botón "← Volver" — lleva al inicio (index) -->
                <!-- Cambia href="/" si el índice de cursos está en otra ruta -->
                <a href="/" class="boton-volver">&larr; Volver a los cursos</a>

                <!-- Encabezado de la lección con su título oficial -->
                <header class="encabezado-clase">
                    <h1>{tituloPagina}</h1>
                </header>

                <!-- <slot /> → aquí se inyecta el contenido del archivo .md -->
                <slot />

                <!-- NAVEGACIÓN INFERIOR: botones Anterior / Siguiente -->
                <!-- Se muestran o se ocultan automáticamente según la posición -->
                <nav class="navegacion-pie-clase">

                    <!-- Botón ANTERIOR: solo aparece si no es la primera lección -->
                    {claseAnterior && cursoActual ? (
                        <a href={`/apuntes/${cursoActual}/${claseAnterior.id}`} class="btn-navegacion anterior">
                            <span class="etiqueta-nav">&larr; Lección Anterior</span>
                            <span class="titulo-nav">{claseAnterior.titulo}</span>
                        </a>
                    ) : (
                        <!-- Espaciador vacío para que "Siguiente" quede a la derecha -->
                        <div class="espaciador-nav"></div>
                    )}

                    <!-- Botón SIGUIENTE: solo aparece si no es la última lección -->
                    {claseSiguiente && cursoActual ? (
                        <a href={`/apuntes/${cursoActual}/${claseSiguiente.id}`} class="btn-navegacion siguiente">
                            <span class="etiqueta-nav">Siguiente Lección &rarr;</span>
                            <span class="titulo-nav">{claseSiguiente.titulo}</span>
                        </a>
                    ) : (
                        <div class="espaciador-nav"></div>
                    )}

                </nav>

            </div>

        </main>
    </div>

</Layout>

<style>
    /* ================================================
       CONTENEDOR PRINCIPAL
       ================================================
       "position: fixed" ancla este div a la pantalla:
       no se mueve aunque hagas scroll. Ocupa todo el
       espacio debajo del header (top: 70px).

       ⚠️ Si cambias la altura del header en Layout.astro,
       actualiza aquí el valor de "top" y "height" también.
       El header actual mide ~70px (padding 16px + texto 22px + bordes).
    ================================================ */
    .contenedor-curso {
        position: fixed;
        top: 70px;                        /* Altura del header — ajusta si cambias el header */
        left: 0;
        width: 100vw;
        height: calc(100vh - 70px);      /* Resto de la pantalla debajo del header */
        display: flex;                   /* Sidebar y contenido en fila horizontal */
        background-color: var(--bg-page);
        z-index: 40;                     /* Flota encima del layout base */
        border-top: 1px solid var(--border-color);
    }

    /* ================================================
       ÁREA DE CONTENIDO PRINCIPAL (derecha)
       ================================================
       "flex-grow: 1" hace que ocupe todo el espacio
       que el sidebar no usa.
       "overflow-y: auto" es la clave: SOLO este div
       hace scroll, no la página completa.
    ================================================ */
    .area-principal {
        flex-grow: 1;
        padding: 3rem 4rem;              /* Espacio interior — reduce si quieres menos margen */
        overflow-y: auto;               /* ← AQUÍ ocurre el scroll de la lección */
        background-color: var(--bg-content);
        color: var(--text-dark);
        scroll-behavior: smooth;        /* Scroll suave al hacer clic en anclas (#) */
    }

    /* ================================================
       BOTÓN "← VOLVER A LOS CURSOS"
    ================================================ */
    .boton-volver {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 2rem;
        color: var(--color-cyan-dark);                 /* Color Alucard Cyan del enlace */
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: transform 0.2s;
    }

    /* Al pasar el mouse, el botón se desplaza levemente a la izquierda */
    .boton-volver:hover {
        transform: translateX(-4px);
        text-decoration: underline;
    }

    /* ================================================
       ENCABEZADO DE LA LECCIÓN
       Línea separadora debajo del título h1
    ================================================ */
    .encabezado-clase {
        border-bottom: 2px solid var(--border-color);
        padding-bottom: 1.5rem;
        margin-bottom: 2rem;
    }

    .encabezado-clase h1 {
        color: var(--title-color);
        font-size: 2.2rem;              /* Tamaño del título de la lección */
        margin: 0 0 0.5rem 0;
        line-height: 1.2;
    }

    /* ================================================
       NAVEGACIÓN INFERIOR — Anterior / Siguiente
    ================================================ */
    .navegacion-pie-clase {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 4rem;
        padding-top: 2rem;
        border-bottom: 4rem solid transparent; /* Espacio extra al final del scroll */
        border-top: 2px solid var(--border-color);
    }

    /* Botón de navegación (card clicable) */
    .btn-navegacion {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 1rem 1.5rem;
        background-color: var(--bg-tarjetas);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.2s ease;
        max-width: 45%;
    }

    /* Al pasar el mouse: borde cyan + sombra + sube ligeramente */
    .btn-navegacion:hover {
        border-color: var(--color-cyan-dark);
        box-shadow: 0 4px 12px rgba(3, 106, 150, 0.15);
        transform: translateY(-2px);
    }

    /* El botón "Siguiente" se alinea a la derecha */
    .btn-navegacion.siguiente {
        align-items: flex-end;
        text-align: right;
        margin-left: auto;
    }

    /* Texto pequeño: "← Lección Anterior" / "Siguiente Lección →" */
    .etiqueta-nav {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--color-cyan-dark);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Título de la lección dentro del botón de navegación */
    .titulo-nav {
        color: var(--title-color);
        font-weight: 600;
        font-size: 1.05rem;
        line-height: 1.3;
    }

    /* Ocupa el espacio del lado donde no hay botón */
    .espaciador-nav {
        flex: 1;
    }

    /* --- ESTILOS PARA LA BARRA DE LENGUAJE DEL CÓDIGO --- */
    :global(.codigo-wrapper) {
        position: relative;
        margin: 2rem 0;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 30px -10px rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.1);
    }

    :global(.codigo-header) {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: var(--header-bg); 
        padding: 8px 16px;
        color: var(--color-cyan); 
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    :global(.codigo-header .copy-btn) {
        cursor: pointer;
        opacity: 0.6;
        transition: opacity 0.2s;
    }

    :global(.codigo-header .copy-btn:hover) {
        opacity: 1;
    }


    /* ================================================
       RESPONSIVIDAD PARA MÓVIL (pantallas ≤ 768px)
       ================================================
       En pantallas pequeñas el layout "fixed" no funciona
       bien, así que lo convertimos a flujo normal.
       El sidebar se oculta — el usuario navega con los
       botones Anterior/Siguiente del pie de página.
    ================================================ */
    @media (max-width: 768px) {
        .contenedor-curso {
            position: static;           /* Ya no está fijo, fluye con la página */
            width: 100%;
            height: auto;
            flex-direction: column;
            border-top: none;
        }

        :global(.sidebar-curso) {
            display: none;              /* Sidebar oculto en móvil */
        }

        .area-principal {
            padding: 1.5rem 1rem;       /* Menos padding en pantallas pequeñas */
            overflow-y: visible;
        }

        .encabezado-clase h1 {
            font-size: 1.5rem;          /* Título más pequeño en móvil */
        }

        .navegacion-pie-clase {
            flex-direction: column;     /* Botones apilados verticalmente */
            gap: 1rem;
        }

        .btn-navegacion {
            max-width: 100%;
            width: 100%;
        }

        .btn-navegacion.siguiente {
            align-items: flex-start;
            text-align: left;
            margin-left: 0;
        }
    }
</style>

<style is:global>
    /* ================================================
       ESTILOS GLOBALES DEL CONTENIDO MARKDOWN
       ================================================
       "is:global" es necesario porque el HTML del .md
       lo genera Astro internamente; sin esto, los estilos
       no llegarían a ese contenido generado.

       ⚠️ Estos estilos sobreescriben el scroll del body
       para que SOLO el .area-principal pueda hacer scroll.
    ================================================ */

    /* Bloqueamos el scroll de la página completa.
       Solo el .area-principal (definido arriba) puede scrollear. */
    body {
        overflow: hidden !important;
    }

    /* Contenedor del texto de la lección */
    .markdown-container {
        max-width: 850px;               /* Ancho máximo del texto — cambia si quieres más/menos */
        margin: 0 auto;
        font-size: 1.15rem;             /* Ligeramente más grande para mejor lectura */
        line-height: 1.8;               /* Espaciado generoso */
    }

    /* Bloques de código (PRE) --- */
    /* Personalizados para que se vean premium */
    .markdown-container pre {
        margin: 0 !important; /* El margen lo controla el wrapper generado por JS */
        padding: 1.5rem !important;
        background-color: var(--bg-page) !important; 
        font-family: 'JetBrains Mono', 'Fira Code', 'Roboto Mono', monospace !important;
        font-size: 0.95rem !important;
        line-height: 1.6 !important;
        overflow-x: auto;
    }

    /* Scrollbar sutil para el código */
    .markdown-container pre::-webkit-scrollbar {
        height: 6px;
    }
    .markdown-container pre::-webkit-scrollbar-thumb {
        background: var(--color-comment-dark);
        border-radius: 10px;
    }


    /* Subtítulos h2, h3, h4 dentro del contenido */
    .markdown-container h2,
    .markdown-container h3,
    .markdown-container h4 {
        color: var(--title-color);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
    }

    /* Párrafos */
    .markdown-container p {
        margin-bottom: 1.5rem;
    }

    /* Tablas dentro del contenido markdown */
    .markdown-container table {
        width: auto;
        min-width: 50%;
        max-width: 100%;
        border-collapse: separate; 
        border-spacing: 0;
        margin: 2.5rem 0;
        background-color: var(--card-bg);
        border-radius: 12px;
        overflow: hidden;
        /* Sombra con un toque aguamarina oscuro */
        box-shadow: 0 10px 30px -10px rgba(44, 124, 140, 0.35); 
        border: none; /* Sin borde exterior duro */
    }

    .markdown-container th,
    .markdown-container td {
        padding: 14px 18px;
        text-align: left;
        border: none; /* Sin líneas separadoras de filas */
    }
    
    /* Sin colores intercalados para las filas de la tabla */
    .markdown-container tr:nth-child(even) {
        background-color: transparent; 
    }

    .markdown-container th {
        background-color: var(--header-bg); 
        font-weight: 700;
        color: var(--text-header); 
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    /* Enlaces dentro del contenido Markdown */
    .markdown-container a {
        color: var(--color-cyan); 
        text-decoration-color: rgba(139, 233, 253, 0.4);
        text-underline-offset: 4px;
        font-weight: 600;
    }

    .markdown-container a:hover {
        text-decoration-color: var(--color-cyan);
    }

    /* Blockquote — bloque de cita/ejemplo -->
       Ahora es transparente siguiendo la directiva visual */
    .markdown-container blockquote {
        background: transparent;
        border-left: 4px solid var(--color-cyan-dark); 
        padding: 1.5rem 2rem;
        margin: 2.5rem 0;
        font-style: italic;
        color: var(--text-main);
    }

    .markdown-container blockquote p {
        margin: 0;
    }


    /* Código inline: `como este` */
    .markdown-container code:not(pre code) {
        padding: 0;
        font-family: 'JetBrains Mono', 'Fira Code', 'Roboto Mono', monospace;
        font-size: 0.9em;
        font-weight: 600;
        color: var(--color-cyan); 
    }
</style>

<script>
    /**
     * SCRIPT PARA ENVOLVER BLOQUES DE CÓDIGO CON CABECERAS
     * Detecta el lenguaje y crea un div con una barra superior estilizada.
     */
    function setupCodeBlocks() {
        const preBlocks = document.querySelectorAll('.markdown-container pre');
        
        preBlocks.forEach(pre => {
            // Evitar duplicados
            if (pre.parentElement?.classList.contains('codigo-wrapper')) return;

            // Detectar lenguaje
            let lang = "Code";
            const classes = Array.from(pre.classList);
            const langClass = classes.find(c => c.startsWith('language-'));
            if (langClass) {
                lang = langClass.replace('language-', '');
            } else {
                const codeElement = pre.querySelector('code');
                if (codeElement) {
                    const codeClasses = Array.from(codeElement.classList);
                    const cLang = codeClasses.find(c => c !== 'astro-code');
                    if (cLang) lang = cLang;
                }
            }

            // Crear el envoltorio
            const wrapper = document.createElement('div');
            wrapper.className = 'codigo-wrapper';
            
            // Crear la cabecera
            const header = document.createElement('div');
            header.className = 'codigo-header';
            header.innerHTML = `
                <span>${lang}</span>
                <span class="copy-btn" title="Copiar código">📋</span>
            `;

            // Insertar en el DOM
            pre.parentNode?.insertBefore(wrapper, pre);
            wrapper.appendChild(header);
            wrapper.appendChild(pre);

            // Funcionalidad de copiar
            header.querySelector('.copy-btn')?.addEventListener('click', () => {
                const text = (pre.textContent || "").trim();
                navigator.clipboard.writeText(text).then(() => {
                    const btn = header.querySelector('.copy-btn');
                    if (btn) {
                        btn.textContent = '✅';
                        setTimeout(() => btn.textContent = '📋', 2000);
                    }
                });
            });
        });
    }

    // Ejecutar al cargar y en cambios de página de Astro
    document.addEventListener('DOMContentLoaded', setupCodeBlocks);
    document.addEventListener('astro:page-load', setupCodeBlocks);
</script>