---
// ============================================================================
// src/layouts/LayoutCurso.astro - El Motor de Renderizado de Clases
// ============================================================================

// 🌟 1. IMPORTAMOS TU LAYOUT PRINCIPAL PARA NO PERDER EL HEADER SUPERIOR
import Layout from './Layout.astro'; 
import SidebarCurso from '../components/SidebarCurso.astro';
import { todosLosTemarios } from '../data/temarios.js';

const { frontmatter } = Astro.props;
const claseActualId = frontmatter.id_clase;

type CursoValido = keyof typeof todosLosTemarios;
const cursoActual = frontmatter.curso as CursoValido; 

const temarioSeleccionado = (cursoActual && todosLosTemarios[cursoActual]) 
    ? todosLosTemarios[cursoActual] 
    : [];

const datosDeEstaClase = temarioSeleccionado.find((clase: any) => clase.id === claseActualId);

const tituloPagina = datosDeEstaClase 
    ? datosDeEstaClase.titulo 
    : (frontmatter.titulo || "Clase Tyac");

const indiceActual = temarioSeleccionado.findIndex((clase: any) => clase.id === claseActualId);
const claseAnterior = indiceActual > 0 ? temarioSeleccionado[indiceActual - 1] : null;
const claseSiguiente = (indiceActual !== -1 && indiceActual < temarioSeleccionado.length - 1) 
    ? temarioSeleccionado[indiceActual + 1] 
    : null;
---

<Layout titulo={`${tituloPagina} - Tyac`}>

    <div class="contenedor-curso">
        
        {temarioSeleccionado.length > 0 && cursoActual && (
            <SidebarCurso 
                lecciones={temarioSeleccionado} 
                claseActualId={claseActualId} 
                cursoActualId={cursoActual}
            />
        )}

        <main class="area-principal">
            
            <div class="markdown-container">
                <a href="/temas" class="boton-volver">&larr; Volver a los cursos</a>
                
                <header class="encabezado-clase">
                    <h1>{tituloPagina}</h1>
                </header>

                <slot />
                
                <nav class="navegacion-pie-clase">
                    {claseAnterior && cursoActual ? (
                        <a href={`/${cursoActual}/${claseAnterior.id}`} class="btn-navegacion anterior">
                            <span class="etiqueta-nav">&larr; Lección Anterior</span>
                            <span class="titulo-nav">{claseAnterior.titulo}</span>
                        </a>
                    ) : (
                        <div class="espaciador-nav"></div>
                    )}

                    {claseSiguiente && cursoActual ? (
                        <a href={`/${cursoActual}/${claseSiguiente.id}`} class="btn-navegacion siguiente">
                            <span class="etiqueta-nav">Siguiente Lección &rarr;</span>
                            <span class="titulo-nav">{claseSiguiente.titulo}</span>
                        </a>
                    ) : (
                        <div class="espaciador-nav"></div>
                    )}
                </nav>

            </div>
            
        </main>
    </div>

</Layout>

<style>
    /* 🌟 LA MAGIA 1: Anclamos el reproductor a la pantalla de forma absoluta */
    .contenedor-curso {
        position: fixed;
        top: 70px; /* 👈 AJUSTA ESTO: Si tu menú es más alto o bajo, cambia este 70px */
        left: 0;
        width: 100vw;
        height: calc(100vh - 70px); /* 👈 AJUSTA ESTE TAMBIÉN igual que el de arriba */
        display: flex;
        background-color: var(--bg-page);
        z-index: 40; /* Asegura que flote por encima del layout base */
        border-top: 1px solid var(--border-color);
    }

    .area-principal {
        flex-grow: 1; 
        padding: 3rem 4rem;
        overflow-y: auto; /* 🌟 Aquí es el ÚNICO lugar donde se permite hacer scroll */
        background-color: var(--bg-page);
        scroll-behavior: smooth;
    }

    .boton-volver {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 2rem;
        color: #3b82f6;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: transform 0.2s;
    }

    .boton-volver:hover {
        transform: translateX(-4px); 
        text-decoration: underline;
    }

    .encabezado-clase {
        border-bottom: 2px solid var(--border-color);
        padding-bottom: 1.5rem;
        margin-bottom: 2rem;
    }

    .encabezado-clase h1 {
        color: var(--title-color);
        font-size: 2.2rem;
        margin: 0 0 0.5rem 0;
        line-height: 1.2;
    }

    .navegacion-pie-clase {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 4rem;
        padding-top: 2rem;
        border-bottom: 4rem solid transparent; /* Da un respiro al final de la página */
        border-top: 2px solid var(--border-color);
    }

    .btn-navegacion {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 1rem 1.5rem;
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.2s ease;
        max-width: 45%;
    }

    .btn-navegacion:hover {
        border-color: #3b82f6;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.1);
        transform: translateY(-2px);
    }

    .btn-navegacion.siguiente {
        align-items: flex-end;
        text-align: right;
        margin-left: auto; 
    }

    .etiqueta-nav {
        font-size: 0.8rem;
        font-weight: 700;
        color: #3b82f6;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .titulo-nav {
        color: var(--title-color);
        font-weight: 600;
        font-size: 1.05rem;
        line-height: 1.3;
    }

    .espaciador-nav {
        flex: 1;
    }
</style>

<style is:global>
    /* 🌟 LA MAGIA 2: Bloqueamos completamente el scroll de la página global */
    body {
        overflow: hidden !important;
    }

    /* Estilos del contenido Markdown */
    .markdown-container {
        max-width: 850px; 
        margin: 0 auto; 
        font-size: 1.1rem;
        line-height: 1.7;
    }

    .markdown-container h2, 
    .markdown-container h3, 
    .markdown-container h4 {
        color: var(--title-color);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
    }

    .markdown-container p {
        margin-bottom: 1.5rem;
    }

    .markdown-container table {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
        background-color: var(--card-bg);
        border-radius: 8px;
        overflow: hidden; 
    }
    
    .markdown-container th, 
    .markdown-container td {
        border: 1px solid var(--border-color);
        padding: 12px 16px;
        text-align: left;
    }

    .markdown-container th {
        background-color: var(--bg-page);
        font-weight: 700;
        color: var(--title-color);
    }

    .markdown-container blockquote {
        background-color: var(--card-bg);
        border-left: 5px solid #3b82f6; 
        padding: 1rem 1.5rem;
        margin: 2rem 0;
        border-radius: 0 8px 8px 0;
        font-style: italic;
        color: var(--text-main);
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }

    .markdown-container blockquote p {
        margin: 0;
    }

    .markdown-container code {
        background-color: var(--code-bg);
        padding: 2px 6px;
        border-radius: 4px;
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.9em;
        color: #ef4444; 
    }
</style>