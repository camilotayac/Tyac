---
// src/layouts/LayoutVertical.astro
import Layout from "./Layout.astro";
import SidebarVertical from "../components/SidebarVertical.astro";
import { todosLosTemarios } from "../data/temarios.js";
import { cursosCiencia } from "../data/cursos.js";
import Footer from "../components/Footer.astro";

import "../styles/markdown-base.css";
import "../styles/markdown-code.css";
import "../styles/markdown-tables.css";
import "../styles/markdown-examples.css";
import "../styles/markdown-links.css";
import "../styles/markdown-formulas.css";

const { frontmatter } = Astro.props;
const claseActualId = frontmatter.id_clase;

type CursoValido = keyof typeof todosLosTemarios;
const cursoActual = frontmatter.curso as CursoValido;

const temarioSeleccionado =
    cursoActual && todosLosTemarios[cursoActual]
        ? todosLosTemarios[cursoActual]
        : [];

const esCursoAcadémico = cursosCiencia.some((c) => c.id === cursoActual);
const urlPrefix = esCursoAcadémico ? "/cursos" : "/apuntes";

const datosDeEstaClase = temarioSeleccionado.find(
    (clase: any) => clase.id === claseActualId,
);
const tituloPagina = datosDeEstaClase
    ? datosDeEstaClase.titulo
    : frontmatter.titulo || "Clase Tyac";

const indiceActual = temarioSeleccionado.findIndex(
    (clase: any) => clase.id === claseActualId,
);
const claseAnterior =
    indiceActual > 0 ? temarioSeleccionado[indiceActual - 1] : null;
const claseSiguiente =
    indiceActual !== -1 && indiceActual < temarioSeleccionado.length - 1
        ? temarioSeleccionado[indiceActual + 1]
        : null;
---

<Layout titulo={`${tituloPagina} - Tyac`}>

    <div class="vertical-layout">
        <!-- Sidebar -->
        {
            temarioSeleccionado.length > 0 && cursoActual && (
                <SidebarVertical
                    lecciones={temarioSeleccionado}
                    claseActualId={claseActualId}
                    cursoActualId={cursoActual}
                />
            )
        }

        <!-- Main Content (Cambiamos el contenido con una transición suave) -->
        <main class="main-viewport" transition:animate="fade">
            <div class="content-scroller">
                <div class="content-max-width">
                    <nav class="breadcrumb-nav">
                        <a
                            href={`${urlPrefix}/${cursoActual}`}
                            class="back-link"
                        >
                            <span class="back-icon">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="3"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><line x1="19" y1="12" x2="5" y2="12"
                                    ></line><polyline points="12 19 5 12 12 5"
                                    ></polyline></svg
                                >
                            </span>
                            Volver al temario
                        </a>
                    </nav>

                    <article class="markdown-body">
                        <slot />
                    </article>

                    <!-- Bottom Nav -->
                    <footer class="lesson-pagination">
                        {
                            claseAnterior ? (
                                <a
                                    href={`${urlPrefix}/${cursoActual}/${claseAnterior.id}`}
                                    class="nav-btn prev"
                                >
                                    <span class="nav-label">Anterior</span>
                                    <span class="nav-title">
                                        {claseAnterior.titulo}
                                    </span>
                                </a>
                            ) : (
                                <div class="nav-spacer" />
                            )
                        }

                        {
                            claseSiguiente ? (
                                <a
                                    href={`${urlPrefix}/${cursoActual}/${claseSiguiente.id}`}
                                    class="nav-btn next"
                                >
                                    <span class="nav-label">Siguiente</span>
                                    <span class="nav-title">
                                        {claseSiguiente.titulo}
                                    </span>
                                </a>
                            ) : (
                                <div class="nav-spacer" />
                            )
                        }
                    </footer>
                </div>

                <!-- Footer restaurado al ancho total de la página -->
                <Footer />
            </div>
        </main>
    </div>
</Layout>

<style>
    .vertical-layout {
        display: flex;
        height: calc(100vh - 64px); /* Sincronizado con Layout.astro header */
        background-color: var(--header-bg); /* Mismo fondo que la cabecera */
        overflow: hidden;
    }

    .main-viewport {
        flex: 1;
        overflow: hidden;
        position: relative;
        background-color: #ffffff; /* Blanco para máxima legibilidad del MD */
    }

    .content-scroller {
        height: 100%;
        overflow-y: auto;
        padding: 0; /* Eliminado el padding lateral para evitar franjas blancas entre sidebar y contenido */
        scroll-behavior: smooth;
    }

    .content-max-width {
        max-width: 850px;
        margin: 0 auto;
        padding: 2rem 1rem 8rem 1rem; /* Reducido de 4rem a 2rem para quitar el espacio excesivo */
    }

    /* Header & Back */
    .breadcrumb-nav {
        margin-bottom: 2.5rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        color: var(--texto-atenuado);
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }

    .back-icon {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.03);
        border: 1px solid rgba(0, 0, 0, 0.05);
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .back-link:hover {
        color: var(--acento);
    }

    .back-link:hover .back-icon {
        background: var(--acento-fondo-activo);
        border-color: var(--acento);
        color: var(--acento);
        transform: translateX(-3px);
    }

    .lesson-header {
        display: none; /* Removed as requested: title is in MD */
    }

    .lesson-header h1 {
        font-size: 2.8rem;
        font-weight: 800;
        color: var(--texto-oscuro);
        margin: 0;
        line-height: 1.1;
    }

    /* Markdown Article */
    .markdown-body {
        font-size: 1.05rem;
        line-height: 1.7;
        color: var(--texto-oscuro);
    }

    /* Pagination */
    .lesson-pagination {
        display: flex;
        justify-content: space-between;
        margin-top: 6rem;
        padding-top: 3rem;
        border-top: 1px solid var(--markdown-borde);
        gap: 2rem;
    }

    .nav-btn {
        flex: 1;
        padding: 1.5rem;
        background: #f8fafc;
        border: 1px solid var(--markdown-borde);
        border-radius: 16px;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        gap: 6px;
        transition: all 0.2s;
        max-width: 48%;
    }

    .nav-btn:hover {
        border-color: var(--acento);
        background: #f1f5f9;
        transform: translateY(-2px);
    }

    .nav-btn.next {
        align-items: flex-end;
        text-align: right;
    }

    .nav-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--acento);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .nav-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--texto-oscuro);
    }

    .nav-spacer {
        flex: 1;
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 1024px) {
        .content-max-width {
            padding: 2rem 0.5rem 6rem 0.5rem;
        }
    }
</style>

<style is:global>
    /* Block body scroll for independent viewport scroll */
    body {
        overflow: hidden !important;
    }

    /* Global styles for dark/light mode switches if needed */
    :global(.sidebar-collapsed) .main-viewport {
        /* Optional: adjust some content margin if necessary */
    }
</style>

<script>
    function setupSidebar() {
        const toggleBtn = document.getElementById("toggle-sidebar");
        const body = document.body;

        // Re-aplicar estado desde localStorage para asegurar consistencia tras navegación
        if (localStorage.getItem("sidebar-collapsed") === "true") {
            body.classList.add("sidebar-collapsed");
        } else {
            body.classList.remove("sidebar-collapsed");
        }

        toggleBtn?.addEventListener("click", () => {
            const nowCollapsed = body.classList.toggle("sidebar-collapsed");
            localStorage.setItem("sidebar-collapsed", nowCollapsed.toString());
        });
    }

    function setupCodeBlocks() {
        const preBlocks = document.querySelectorAll(".markdown-body pre");
        preBlocks.forEach((pre) => {
            if (pre.parentElement?.classList.contains("codigo-wrapper")) return;
            let lang = "Code";
            const classes = Array.from(pre.classList);
            const langClass = classes.find((c) => c.startsWith("language-"));
            if (langClass) lang = langClass.replace("language-", "");

            const wrapper = document.createElement("div");
            wrapper.className = "codigo-wrapper";
            const header = document.createElement("div");
            header.className = "codigo-header";
            header.innerHTML = `<span>${lang}</span><span class="copy-btn">📋</span>`;

            pre.parentNode?.insertBefore(wrapper, pre);
            wrapper.appendChild(header);
            wrapper.appendChild(pre);

            header.querySelector(".copy-btn")?.addEventListener("click", () => {
                navigator.clipboard
                    .writeText(pre.textContent || "")
                    .then(() => {
                        const btn = header.querySelector(".copy-btn");
                        if (btn) {
                            btn.textContent = "✅";
                            setTimeout(() => (btn.textContent = "📋"), 2000);
                        }
                    });
            });
        });
    }

    document.addEventListener("DOMContentLoaded", setupCodeBlocks);
    document.addEventListener("astro:page-load", setupCodeBlocks);
</script>
