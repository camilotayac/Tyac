---
/**
 * 00-LAYOUTLESSONS.ASTRO
 * Master orchestrator for lesson views
 * Orquestador maestro para vistas de lecciones
 */

// Core Layout & Components / Layout Base y Componentes
import Footer from "../../components/Footer.astro";
import Layout from "../head/00-Layout.astro";
import SidebarVertical from "../../components/SidebarVertical.astro";
import Breadcrumbs from "../courses/03-Breadcrumbs.astro";
import Pagination from "../courses/04-Pagination.astro";
import IconoElegante from "../../components/IconoElegante.astro";

// Data & Assets / Datos y Recursos
import { getTemario } from "../../data/temarios.js";
import { getCursosCiencia } from "../../data/cursos.js";
import { getApuntesTecnicos } from "../../data/apuntes.js";

// Global Markdown Styles / Estilos globales de Markdown
import "../../styles/markdown/01-Base.css";
import "../../styles/markdown/02-Code.css";
import "../../styles/markdown/03-Tables.css";
import "../../styles/markdown/04-Links.css";
import "../../styles/markdown/05-Formulas.css";
import "../../styles/markdown/06-Examples.css";

// Props & Navigation Logic / Props y Lógica de Navegación
const { frontmatter } = Astro.props;
const lessonId = frontmatter.id_clase;

const currentCourse = frontmatter.curso;
const [selectedSyllabus, allCursos, allApuntes] = await Promise.all([
    getTemario(currentCourse),
    getCursosCiencia(),
    getApuntesTecnicos()
]);

const isAcademicCourse = allCursos.some((c: any) => c.id === currentCourse);
const urlPrefix = isAcademicCourse ? "/cursos" : "/apuntes";

// Búsqueda del curso padre para sacar su nivel y total
const baseCollection = isAcademicCourse ? allCursos : allApuntes;
const cursoObj = baseCollection.find((c: any) => c.id === currentCourse);
const nivelC = cursoObj ? cursoObj.nivel : (isAcademicCourse ? "Básico" : "Intermedio");
const totalC = selectedSyllabus.length; // Usamos el total real calculado del temario

const lessonData = selectedSyllabus.find(
    (lesson: any) => lesson.id === lessonId,
);
const pageTitle = lessonData
    ? lessonData.titulo
    : frontmatter.titulo || "Clase Tyac";

const currentIndex = selectedSyllabus.findIndex(
    (lesson: any) => lesson.id === lessonId,
);

const prevLesson = currentIndex > 0 ? selectedSyllabus[currentIndex - 1] : null;
const nextLesson =
    currentIndex !== -1 && currentIndex < selectedSyllabus.length - 1
        ? selectedSyllabus[currentIndex + 1]
        : null;
---

<Layout titulo={`${pageTitle} - Tyac`}>
    <div class="lessons-layout">
        <!-- Sidebar Navigation / Navegación lateral -->
        {
            selectedSyllabus.length > 0 && currentCourse && (
                <SidebarVertical
                    lecciones={selectedSyllabus}
                    claseActualId={lessonId}
                    cursoActualId={currentCourse}
                />
            )
        }

        <main class="lessons-viewport" transition:animate="fade">
            <div class="lessons-scroller">
                <div class="lessons-max-width">
                    <div class="sticky-header-bar">
                        <Breadcrumbs
                            urlPrefix={urlPrefix}
                            courseId={currentCourse}
                        />

                    <div class="lesson-meta-bar">
                        <div class="meta-pill">
                            <IconoElegante nombre="niveles" size="14px" class="pill-icon" />
                            <span>Nivel {nivelC}</span>
                        </div>
                        <div class="meta-pill">
                            <IconoElegante nombre="clases" size="14px" class="pill-icon" />
                            <span>{totalC} {isAcademicCourse ? 'clases' : 'temas'}</span>
                        </div>
                        <div class="meta-pill materia">
                            <span>{frontmatter.materia || "General"}</span>
                        </div>
                    </div>
                    </div> <!-- CIERRE DE STICKY HEADER -->

                    <article class="markdown-container">
                        <slot />
                    </article>

                    <Pagination
                        prevLesson={prevLesson}
                        nextLesson={nextLesson}
                        urlPrefix={urlPrefix}
                        courseId={currentCourse}
                    />
                </div>

                <Footer />
            </div>
        </main>
    </div>
</Layout>

<style>
    /* Lessons Structural Layout / Maquetación estructural de lecciones */
    .lessons-layout {
        display: flex;
        height: calc(100vh - 64px);
        background-color: var(--clr-black-01);
        overflow: hidden;
    }

    .lessons-viewport {
        flex: 1;
        overflow: hidden;
        position: relative;
        background-color: var(--clr-white-pure); /* Fondo de lectura claro */
    }

    .lessons-scroller {
        height: 100%;
        overflow-y: auto;
        padding: 0;
        scroll-behavior: smooth;
    }

    .lessons-max-width {
        max-width: 850px;
        margin: 0 auto;
        padding: 0 1rem 8rem 1rem;
    }

    /* Sticky Bar */
    .sticky-header-bar {
        position: sticky;
        top: 0;
        z-index: 40;
        background: rgba(255, 255, 255, 0.95); /* Blanco translúcido */
        backdrop-filter: blur(10px);
        padding: 2rem 0 0.5rem 0;
        margin-bottom: 2rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05); /* Separador suave oscuro */
    }

    /* Meta Pills (Platzi-style signal bars) */
    .lesson-meta-bar {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin: 1.5rem 0 0.5rem 0;
        padding-bottom: 0;
    }

    .meta-pill {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--clr-black-02, #2a2b3d);
        background-color: #f1f3f5;
        border: 1px solid rgba(0, 0, 0, 0.1);
        padding: 5px 12px;
        border-radius: 8px;
    }

    .pill-icon {
        opacity: 0.6;
        color: var(--clr-black-02);
    }

    .meta-pill.materia span {
        color: var(--dracula-purple);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    @media (max-width: 1024px) {
        .lessons-max-width {
            padding: 2rem 0.5rem 6rem 0.5rem;
        }
    }
</style>

<style is:global>
    body {
        overflow: hidden !important;
    }
</style>

<script>
    // @ts-nocheck
    /** @param {any} el */
    function getLanguageFromElement(el) {
        if (!el) return null;
        const classList = Array.from(el.classList);
        const forbidden = [
            "shiki",
            "dracula",
            "markdown-container",
            "astro-",
            "codigo-wrapper",
            "has-focused",
        ];

        // 1. Buscar lenguaje explícito (formato loop para evitar 'implicit any' en arrow functions)
        for (const cls of classList) {
            if (typeof cls === "string") {
                if (cls.startsWith("language-"))
                    return cls.replace("language-", "");
                if (cls.startsWith("lang-")) return cls.replace("lang-", "");
            }
        }

        // 2. Buscar clase aislada (filtrando temas/librerías)
        for (const cls of classList) {
            if (typeof cls === "string") {
                let isForbidden = false;
                for (const f of forbidden) {
                    if (cls.startsWith(f)) {
                        isForbidden = true;
                        break;
                    }
                }
                if (!isForbidden) return cls;
            }
        }

        return null;
    }

    function setupCodeBlocks() {
        const preBlocks = document.querySelectorAll(".markdown-container pre");

        for (const pre of Array.from(preBlocks)) {
            const preElement = pre; // Cast implícito
            if (preElement.parentElement?.classList.contains("codigo-wrapper"))
                continue;

            // Prioridad: Atributo data-language
            let lang = preElement.getAttribute("data-language");

            // Si no hay atributo, buscamos en las clases
            if (!lang || lang === "text") {
                lang =
                    getLanguageFromElement(preElement) ||
                    getLanguageFromElement(preElement.querySelector("code")) ||
                    "text";
            }

            const copySvg = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-top:2px"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;
            const checkSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#50fa7b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-top:2px"><path d="M20 6 9 17l-5-5"/></svg>`;

            const wrapper = document.createElement("div");
            wrapper.className = "codigo-wrapper";
            const header = document.createElement("div");
            header.className = "codigo-header";
            header.innerHTML = `<span>Code: ${lang}</span><span class="copy-btn" title="Copiar código">${copySvg}</span>`;

            if (preElement.parentNode) {
                preElement.parentNode.insertBefore(wrapper, preElement);
                wrapper.appendChild(header);
                wrapper.appendChild(preElement);

                const copyBtn = header.querySelector(".copy-btn");
                if (copyBtn) {
                    copyBtn.addEventListener("click", () => {
                        const text = preElement.textContent || "";
                        navigator.clipboard.writeText(text).then(() => {
                            copyBtn.innerHTML = checkSvg;
                            setTimeout(() => (copyBtn.innerHTML = copySvg), 2000);
                        });
                    });
                }
            }
        }
    }

    document.addEventListener("DOMContentLoaded", setupCodeBlocks);
    document.addEventListener("astro:page-load", setupCodeBlocks);
</script>
