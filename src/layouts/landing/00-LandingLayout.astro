---
import Layout from "../head/00-Layout.astro";
import { getTemario } from "../../data/temarios.js";
import { getCursosCiencia } from "../../data/cursos.js";
import { getApuntesTecnicos } from "../../data/apuntes.js";
import IconoElegante from "../../components/IconoElegante.astro";
import TarjetaHorizontal from "../../components/TarjetaHorizontal.astro";

interface Props {
    curso: {
        id: string;
        titulo: string;
        descripcion: string;
        icono: string;
        materia: string;
        href: string;
        lecciones: number;
        nivel: string;
        profesor: string;
    };
    tipo: "curso" | "apunte";
}

const { curso, tipo } = Astro.props;

// 1. Obtener sub-cursos (si es un portal)
const allCollection = tipo === "curso" ? await getCursosCiencia() : await getApuntesTecnicos();
const subCursos = allCollection.filter(c => (c as any).parentId === curso.id);
const esPortal = subCursos.length > 0;

// Definir el prefijo de URL según el tipo
const urlPrefix = tipo === "curso" ? "/cursos" : "/apuntes";

// 2. Obtener el temario automáticamente o de forma manual (Híbrido)
const temarioRaw = await getTemario(curso.id);

// 3. Obtener el ID de la primera lección para el botón CTA
const primerIdClase = temarioRaw.length > 0 ? temarioRaw[0].id : "#";

// Variable para rastrear secciones en el loop
let lastSection = "";
---

<Layout titulo={`${curso.titulo} - Tyac`}>
    <div class="landing-page">
        <!-- 1. HERO (Efecto Spotlight) -->
        <header class="hero-section">
            <div class="hero-glow"></div>
            <div class="container container-hero">
                <div class="btn-back-container">
                    <a href="/" class="btn-minimal-back">&larr; Volver al inicio</a>
                </div>
                <div class="meta-badges">
                    <span class="badge badge-accent">{curso.materia}</span>
                    <span class="badge badge-secondary">{curso.nivel}</span>
                    <span class="badge badge-secondary">{temarioRaw.length} temas</span>
                </div>
                <h1 class="page-title">{curso.titulo}</h1>
                <p class="page-description">
                    {curso.descripcion} {tipo === "curso" ? "Domina los fundamentos académicos con rigor y claridad." : "Guía práctica y técnica para el desarrollo moderno."}
                </p>
            </div>
        </header>

        <!-- Contenido principal / Main Content -->
        <main class="grid-section">
            <div class:list={["container main-grid", { "is-portal": esPortal }]} data-portal={esPortal}>
                <!-- Columna Izquierda: Temario o Portal -->
                <section class="syllabus-column">
                    <h2 class="section-subtitle">
                        {esPortal ? "Sub-cursos disponibles" : (tipo === "curso" ? "Estructura del curso" : "Contenido técnico")}
                    </h2>

                    {esPortal ? (
                        <div class="portal-grid">
                            {subCursos.map((sub: any) => (
                                <a href={sub.href} class="portal-link">
                                    <TarjetaHorizontal
                                        titulo={sub.titulo}
                                        descripcion={sub.descripcion}
                                        icono={sub.icono}
                                        cantidadTemas={String(sub.lecciones)}
                                    />
                                </a>
                            ))}
                        </div>
                    ) : (
                        <div class="timeline">
                            {temarioRaw.length > 0 ? (
                                temarioRaw.map((leccion: any, index: number) => {
                                    const isNewSection = (leccion as any).subcurso && (leccion as any).subcurso !== lastSection;
                                    if (isNewSection) {
                                        lastSection = (leccion as any).subcurso;
                                    }

                                    return (
                                        <>
                                            {isNewSection && (
                                                <div class="timeline-section-title">
                                                    <span>{(leccion as any).subcurso}</span>
                                                </div>
                                            )}
                                            <a href={`${urlPrefix}/${curso.id}/${leccion.id}`} class="timeline-item">
                                        <div class="timeline-v-line"></div>
                                        <div class="marker-container">
                                            <div class="diamond-marker">
                                                <span>{index + 1}</span>
                                            </div>
                                        </div>
                                        <div class="card-content">
                                            <div class="lesson-card">
                                                <div class="lesson-text">
                                                    <h3>{leccion.titulo}</h3>
                                                    {tipo === "curso" ? (
                                                        <span class="duration">
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                                            {(leccion as any).duracion} min
                                                        </span>
                                                    ) : (
                                                        <div class="difficulty-tag">
                                                            <IconoElegante nombre="niveles" size="14px" />
                                                            <span>{(leccion as any).dificultad}</span>
                                                        </div>
                                                    )}
                                                </div>
                                                <span class="action-hint">Leer más &rarr;</span>
                                            </div>
                                        </div>
                                    </a>
                                        </>
                                    );
                                })
                            ) : (
                                <div class="empty-state">
                                    <p>El contenido se está preparando. Vuelve pronto para explorar los temas.</p>
                                </div>
                            )}
                        </div>
                    )}
                </section>

                <!-- Columna Derecha: Sidebar Sticky (Solo si NO es portal) -->
                {!esPortal && (
                    <aside class="sidebar-column">
                        <div class="glass-card sticky-cta">
                            <div class="preview-hero">
                                <div class="preview-overlay"></div>
                                <div class="preview-visual"></div>
                                <div class="play-trigger">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="#bd93f9" stroke="none"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                                </div>
                            </div>

                            <div class="card-content-body">
                                <div class="pricing-info">
                                    <span class="label">Acceso Abierto</span>
                                    <div class="value">Gratis y Público</div>
                                </div>

                                <div class="cta-box">
                                    <a href={`${urlPrefix}/${curso.id}/${primerIdClase}`} class="cta-button">
                                        Empezar lectura
                                    </a>
                                </div>

                                <ul class="feature-list">
                                    <li>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="check-svg"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                        Contenido premium
                                    </li>
                                    <li>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="check-svg"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                        100% gratuito
                                    </li>
                                    <li>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="check-svg"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                        Tu ritmo, tu tiempo
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </aside>
                )}
            </div>
        </main>
    </div>
</Layout>

<style>
    .landing-page {
        min-height: 100vh;
        background-color: var(--clr-black-01);
        color: var(--clr-black-text);
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    /* --- HERO --- */
    .hero-section {
        position: relative;
        padding: 4rem 0 3.5rem 0;
        overflow: hidden;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .btn-back-container { margin-bottom: 2rem; }

    .btn-minimal-back {
        color: var(--clr-gray-muted);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.2s;
    }

    .btn-minimal-back:hover { color: var(--dracula-purple); }

    .hero-glow {
        position: absolute;
        top: -20%;
        left: 50%;
        transform: translateX(-50%);
        width: 1000px;
        height: 600px;
        background: radial-gradient(circle, rgba(189, 147, 249, 0.1) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
    }

    .container-hero { position: relative; z-index: 1; }

    .meta-badges {
        display: flex;
        gap: 12px;
        margin-bottom: 1rem;
    }

    .badge {
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .badge-accent { background: var(--dracula-purple); color: #191a21; border: none; }
    .badge-secondary { background: rgba(255, 255, 255, 0.05); color: var(--clr-gray-muted); }

    .page-title {
        font-size: 3rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 1.2rem;
        color: var(--clr-white-soft);
    }

    .page-description {
        font-size: 1.1rem;
        color: var(--clr-gray-muted);
        max-width: 700px;
        line-height: 1.6;
    }

    /* --- GRID --- */
    .grid-section { padding: 3.5rem 0 8rem 0; }

    .main-grid {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 4rem;
        align-items: flex-start;
    }

    .main-grid.is-portal {
        grid-template-columns: 1fr;
    }

    .main-grid.is-portal .sidebar-column {
        display: none !important;
    }

    /* --- TIMELINE (Diamond) --- */
    .section-subtitle {
        font-size: 1.6rem;
        font-weight: 800;
        margin-bottom: 2.5rem;
        color: var(--clr-white-soft);
    }

    /* --- PORTAL GRID --- */
    .portal-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2.5rem;
    }

    .main-grid.is-portal .portal-grid {
        grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
        gap: 3rem;
    }

    .portal-link {
        text-decoration: none;
        display: block;
    }

    @media (max-width: 600px) {
        .portal-grid { grid-template-columns: 1fr; }
    }

    .timeline { display: flex; flex-direction: column; }

    .timeline-section-title {
        padding: 2.5rem 0 1rem 0;
        margin-bottom: 1rem;
        position: relative;
        z-index: 1;
        background: var(--clr-black-01);
    }

    .timeline-section-title span {
        font-size: 0.8rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--dracula-purple);
        background: rgba(189, 147, 249, 0.1);
        padding: 6px 16px;
        border-radius: 20px;
        border: 1px solid rgba(189, 147, 249, 0.2);
    }

    .timeline-item {
        position: relative;
        display: flex;
        align-items: center;
        gap: 2rem;
        padding-bottom: 2rem;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s ease;
    }

    .timeline-v-line {
        position: absolute;
        left: 20px;
        top: 50%;
        bottom: -50%;
        width: 2px;
        background: linear-gradient(to bottom, rgba(189, 147, 249, 0.2) 0%, transparent 100%);
        z-index: 0;
    }

    .timeline-item:last-child .timeline-v-line { display: none; }

    .marker-container {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
    }

    .diamond-marker {
        width: 38px;
        height: 38px;
        background: #1e1f29;
        border: 2px solid var(--dracula-purple);
        transform: rotate(45deg);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 15px rgba(189, 147, 249, 0.2);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .diamond-marker span {
        transform: rotate(-45deg);
        font-weight: 800;
        font-size: 1rem;
        color: var(--clr-white-soft);
    }

    .timeline-item:hover .diamond-marker {
        background: var(--dracula-purple);
        box-shadow: 0 0 20px rgba(189, 147, 249, 0.4);
    }

    .timeline-item:hover .diamond-marker span { color: #191a21; }

    .card-content { flex: 1; }

    .lesson-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.04);
        padding: 1.2rem 1.5rem;
        border-radius: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.3s ease;
    }

    .timeline-item:hover .lesson-card {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(189, 147, 249, 0.15);
        transform: translateY(-2px);
    }

    .lesson-text h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
        color: var(--clr-white-soft);
    }

    .duration, .difficulty-tag {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--clr-gray-muted);
    }

    .difficulty-tag {
        color: #0369a1; /* Azul océano profundo */
    }

    .action-hint {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--dracula-purple);
        opacity: 0.6;
        transition: all 0.2s;
    }

    .timeline-item:hover .action-hint {
        opacity: 1;
        transform: translateX(3px);
    }

    .empty-state {
        padding: 3rem;
        background: rgba(255,255,255,0.02);
        border-radius: 12px;
        text-align: center;
        color: var(--clr-gray-muted);
        border: 1px dashed rgba(255,255,255,0.1);
    }

    /* --- SIDEBAR --- */
    .sidebar-column { position: sticky; top: 100px; z-index: 10; }

    .glass-card {
        background: rgba(30, 31, 41, 0.6);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .preview-hero {
        aspect-ratio: 16/9;
        background: #0d0d0f;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .preview-overlay {
        position: absolute;
        inset: 0;
        background: url('https://images.unsplash.com/photo-1517694712202-14dd9538aa97?auto=format&fit=crop&q=80&w=800') center/cover;
        opacity: 0.25;
        z-index: 1;
    }

    .preview-visual {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.8));
        z-index: 2;
    }

    .play-trigger {
        position: relative;
        z-index: 3;
        color: white;
        filter: drop-shadow(0 0 15px rgba(189, 147, 249, 0.6));
        transition: transform 0.3s ease;
    }

    .glass-card:hover .play-trigger { transform: scale(1.1); }

    .card-content-body { padding: 1.8rem; }

    .pricing-info { margin-bottom: 1.8rem; text-align: center; }

    .label {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--clr-gray-muted);
        text-transform: uppercase;
        letter-spacing: 1.2px;
    }

    .value {
        font-size: 1.6rem;
        font-weight: 900;
        color: var(--clr-white-soft);
        margin-top: 0.4rem;
        letter-spacing: -0.5px;
    }

    .cta-box { width: 100%; box-sizing: border-box; margin-bottom: 1.8rem; }

    .cta-button {
        display: block;
        width: 100%;
        box-sizing: border-box;
        padding: 1.1rem;
        background: linear-gradient(135deg, var(--dracula-purple) 0%, #a275e5 100%);
        color: #191a21;
        text-align: center;
        text-decoration: none;
        font-weight: 800;
        font-size: 1rem;
        border-radius: 10px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(189, 147, 249, 0.2);
    }

    .cta-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(189, 147, 249, 0.4);
        filter: brightness(1.1);
    }

    .feature-list { list-style: none; padding: 0; margin: 0; }

    .feature-list li {
        display: flex;
        gap: 10px;
        margin-bottom: 0.8rem;
        font-size: 0.85rem;
        color: var(--clr-gray-muted);
        line-height: 1.4;
    }

    .check-svg { 
        color: #50fa7b; 
        flex-shrink: 0;
        margin-top: 2px;
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 900px) {
        .main-grid { grid-template-columns: 1fr; gap: 3rem; }
        .sidebar-column { order: -1; position: static; }
        .page-title { font-size: 2.2rem; }
    }
</style>
