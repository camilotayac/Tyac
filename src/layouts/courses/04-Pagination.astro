---
// src/layouts/courses/04-Pagination.astro
interface Props {
    prevLesson: any;
    nextLesson: any;
    urlPrefix: string;
    courseId: string;
}

const { prevLesson, nextLesson, urlPrefix, courseId } = Astro.props;
---

<nav class="pagination-nav">
    {prevLesson ? (
        <a href={`${urlPrefix}/${courseId}/${prevLesson.id}`} class="pagination-btn prev">
            <span class="btn-label">Anterior</span>
            <span class="lesson-title">{prevLesson.titulo}</span>
        </a>
    ) : (
        <div class="pagination-placeholder"></div>
    )}

    {nextLesson ? (
        <a href={`${urlPrefix}/${courseId}/${nextLesson.id}`} class="pagination-btn next">
            <span class="btn-label">Siguiente</span>
            <span class="lesson-title">{nextLesson.titulo}</span>
        </a>
    ) : (
        <div class="pagination-placeholder"></div>
    )}
</nav>

<style>
    .pagination-nav {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(0, 0, 0, 0.05);
    }

    .pagination-btn {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 1.5rem;
        background: #fafafa;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.3s ease;
        max-width: 48%;
    }

    .pagination-btn:hover {
        background: rgba(189, 147, 249, 0.05);
        border-color: var(--dracula-purple, #bd93f9);
        transform: translateY(-2px);
    }

    .pagination-btn.prev {
        align-items: flex-start;
        text-align: left;
    }

    .pagination-btn.next {
        align-items: flex-end;
        text-align: right;
    }

    .btn-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--clr-gray-muted, #7e7e8d);
        margin-bottom: 5px;
    }

    .lesson-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--clr-black-02);
    }

    .pagination-placeholder {
        flex: 1;
    }
</style>
