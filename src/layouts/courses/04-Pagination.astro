---
/**
 * 02-PAGINATION.ASTRO
 * Bottom navigation for jumping between lessons
 * Navegación inferior para saltar entre lecciones
 */

interface Lesson {
    id: string;
    titulo: string;
}

interface Props {
    prevLesson: Lesson | null;
    nextLesson: Lesson | null;
    urlPrefix: string;
    courseId: string;
}

const { prevLesson, nextLesson, urlPrefix, courseId } = Astro.props;
---

<footer class="lesson-pagination">
    {
        prevLesson ? (
            <a href={`${urlPrefix}/${courseId}/${prevLesson.id}`} class="pag-link prev">
                <span class="pag-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                </span>
                <span class="pag-text">
                    Anterior: {prevLesson.titulo}
                </span>
            </a>
        ) : (
            <div class="pag-spacer" />
        )
    }

    {
        nextLesson ? (
            <a href={`${urlPrefix}/${courseId}/${nextLesson.id}`} class="pag-link next">
                <span class="pag-text">
                    Siguiente: {nextLesson.titulo}
                </span>
                <span class="pag-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </span>
            </a>
        ) : (
            <div class="pag-spacer" />
        )
    }
</footer>

<style is:global>
    .lesson-pagination {
        display: flex;
        justify-content: space-between;
        margin-top: 6rem;
        padding-top: 4rem;
        border-top: 1px solid var(--c-border);
        gap: 1.5rem;
    }

    /* Pill Navigation Structure */
    .lesson-pagination .pag-link {
        display: inline-flex !important;
        align-items: center;
        gap: 14px;
        color: var(--c-muted) !important;
        text-decoration: none !important;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0, 1);
        padding: 8px 16px;
        background: transparent !important;
        border: 1px solid var(--c-border) !important;
        border-radius: 100px !important;
        max-width: 48%;
    }

    .lesson-pagination .pag-link.prev {
        padding-left: 8px;
    }

    .lesson-pagination .pag-link.next {
        padding-right: 8px;
        text-align: right;
        justify-content: flex-end;
    }

    /* Icon styling identical to Breadcrumbs */
    .lesson-pagination .pag-icon {
        width: 38px;
        height: 38px;
        min-width: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        border: 1px solid var(--c-border);
        border-radius: 50%;
        color: var(--c-text);
        transition: all 0.4s cubic-bezier(0.4, 0, 0, 1);
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }

    .lesson-pagination .pag-text {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: var(--c-text);
    }

    /* Hover States matching Breadcrumbs */
    .lesson-pagination .pag-link:hover {
        color: var(--c-text) !important;
        border-color: var(--c-text) !important;
        background: #fff !important;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    .lesson-pagination .pag-link.prev:hover .pag-icon {
        background: var(--c-text);
        color: #fff;
        transform: translateX(-4px) scale(1.05);
    }

    .lesson-pagination .pag-link.next:hover .pag-icon {
        background: var(--c-text);
        color: #fff;
        transform: translateX(4px) scale(1.05);
    }

    .lesson-pagination .pag-spacer {
        flex: 1;
    }

    @media (max-width: 768px) {
        .lesson-pagination { flex-direction: column; gap: 1rem; }
        .lesson-pagination .pag-link { max-width: 100%; justify-content: space-between; }
        .lesson-pagination .pag-text { white-space: normal; }
    }
</style>
