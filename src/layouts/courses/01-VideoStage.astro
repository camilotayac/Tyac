---
/**
 * 01-VIDEOSTAGE.ASTRO
 * Masterclass Video Environment
 * El escenario premium donde ocurre la magia del video.
 */

import Breadcrumbs from "./03-Breadcrumbs.astro";

const { videoId, pageTitle, currentCourse, urlPrefix, lessonData, isAcademicCourse } = Astro.props;
---

<section class="studio-stage">
    <div class="stage-wrapper">
        <!-- HEADER INFO -->
        <div class="stage-header-info">
            <Breadcrumbs urlPrefix={urlPrefix} courseId={currentCourse} />
            <div class="premium-badge">
                <span class="pulse-dot"></span>
                <span class="academy-tag">ACADEMIC MASTERCLASS</span>
            </div>
        </div>

        <!-- VIDEO FRAME: Oficial YouTube IFrame -->
        <div class="video-theatre-frame">
            <div class="iframe-canvas">
                <div id="youtube-player-v3" data-video-id={videoId}>
                    <div class="player-init-state">
                        <div class="spinner"></div>
                        <span>Cargando Lección...</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- FOOTER INFO -->
        <div class="stage-bottom-info">
            <h1 class="lesson-major-title">{pageTitle}</h1>
            
            <div class="lesson-meta-bar">
                {isAcademicCourse ? (
                    <div class="meta-item time">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                        <span>{(lessonData as any)?.duracion} min de clase</span>
                    </div>
                ) : (
                    <div class="meta-item difficulty">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                        <span>Dificultad: {(lessonData as any)?.dificultad}</span>
                    </div>
                )}
                <div class="meta-separator"></div>
                <div class="meta-item academy">
                    <span>Masterclass Academy</span>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .studio-stage {
        flex: 1;
        background-color: var(--c-stage); /* Coursera inspired bright stage */
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 3rem 2rem; 
        position: relative;
        border-right: 1px solid var(--c-border);
        min-width: 0;
        overflow-y: auto;
    }

    .stage-wrapper {
        width: 100%;
        max-width: 1200px; /* Optimal readability and standard e-learning size */
        display: flex;
        flex-direction: column;
    }

    /* HEADER: Clean layout for navigation and tags */
    .stage-header-info {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 1.5rem;
    }

    .premium-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 6px 14px;
        background: rgba(124, 77, 255, 0.08); /* Subtle accent background */
        border: 1px solid rgba(124, 77, 255, 0.15);
        border-radius: 50px;
        color: var(--c-accent);
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 1.5px;
    }

    .pulse-dot {
        width: 6px; height: 6px;
        background: var(--c-accent);
        border-radius: 50%;
        box-shadow: 0 0 8px var(--c-accent);
        animation: pulse-glow 2s infinite;
    }

    /* THEATRE: Shadow refined, pure 16:9, fully unobscured */
    .video-theatre-frame {
        width: 100%;
        aspect-ratio: 16 / 9;
        background: #000;
        border-radius: 12px; /* Smoother curve */
        overflow: hidden;
        position: relative;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08); /* Sophisticated, lightweight shadow */
        border: 1px solid rgba(0,0,0,0.06);
    }

    .iframe-canvas {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
    }

    #youtube-player-v3 {
        width: 100% !important;
        height: 100% !important;
        display: block;
    }

    .player-init-state {
        width: 100%; height: 100%;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 1rem; color: #fff; font-size: 0.9rem;
    }

    /* BOTTOM INFO */
    .stage-bottom-info {
        margin-top: 1.5rem;
    }

    .lesson-major-title {
        font-size: 2.2rem; /* Professional sizing */
        font-weight: 800;
        color: var(--c-text);
        letter-spacing: -0.5px;
        margin: 0 0 0.8rem 0;
        line-height: 1.2;
    }

    /* Meta Bar for Video Stage (Consistency) */
    .lesson-meta-bar {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--c-muted);
    }

    .meta-item svg {
        color: var(--c-accent);
    }

    .meta-separator {
        width: 4px;
        height: 4px;
        background: var(--c-border);
        border-radius: 50%;
    }

    .meta-item.academy span {
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.75rem;
        color: var(--c-accent);
        opacity: 0.8;
    }

    @keyframes pulse-glow {
        0% { transform: scale(1); opacity: 1; box-shadow: 0 0 0 0 rgba(124, 77, 255, 0.4); }
        70% { transform: scale(1.3); opacity: 0.6; box-shadow: 0 0 0 10px rgba(124, 77, 255, 0); }
        100% { transform: scale(1); opacity: 1; box-shadow: 0 0 0 0 rgba(124, 77, 255, 0); }
    }

    .spinner {
        width: 40px; height: 40px;
        border: 3px solid rgba(255,255,255,0.1); border-top-color: var(--c-accent);
        border-radius: 50%;
        animation: spin 1s infinite linear;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    @media (max-width: 1300px) {
        .studio-stage { padding: 2rem 1.5rem; }
        .stage-header-info { flex-direction: column; align-items: flex-start; gap: 1rem; }
        .lesson-major-title { font-size: 1.8rem; }
    }
</style>
