---
// src/layouts/courses/03-Breadcrumbs.astro
interface Props {
    urlPrefix: string;
    courseId: string;
}

const { urlPrefix, courseId } = Astro.props;

// Formatear el ID para mostrar algo legible
const folderLabel = courseId ? courseId.replace(/_/g, " ") : "";
---

<nav class="breadcrumbs-nav">
    <div class="breadcrumb-item">
        <a href="/">Inicio</a>
    </div>
    <div class="breadcrumb-separator">/</div>
    <div class="breadcrumb-item">
        <a href={urlPrefix}>{urlPrefix === "/cursos" ? "Cursos" : "Apuntes"}</a>
    </div>
    <div class="breadcrumb-separator">/</div>
    <div class="breadcrumb-item active">
        <span class="capitalize">{folderLabel}</span>
    </div>
</nav>

<style>
    .breadcrumbs-nav {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 1rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--clr-black-02);
    }

    .breadcrumb-item a {
        text-decoration: none;
        color: inherit;
        transition: color 0.2s;
    }

    .breadcrumb-item a:hover {
        color: var(--dracula-purple, #bd93f9);
    }

    .breadcrumb-item.active {
        color: var(--dracula-cyan, #8be9fd);
    }

    .breadcrumb-separator {
        opacity: 0.4;
        font-size: 0.7rem;
    }

    .capitalize {
        text-transform: capitalize;
    }
</style>
