---
/**
 * 00-LAYOUTCOURSES.ASTRO
 * Masterclass Studio Orchestrator
 * Orquestador principal que une el escenario de video y el panel de apuntes.
 */

import Layout from "../head/00-Layout.astro";
import SidebarVertical from "../../components/SidebarVertical.astro";
import VideoStage from "./01-VideoStage.astro";
import TranscriptPane from "./02-TranscriptPane.astro";
import { todosLosTemarios } from "../../data/temarios.js";
import { cursosCiencia } from "../../data/cursos.js";

const { frontmatter, videoId } = Astro.props;
const lessonId = frontmatter.id_clase;

type CourseValidKey = keyof typeof todosLosTemarios;
const currentCourse = frontmatter.curso as CourseValidKey;

const selectedSyllabus = currentCourse && todosLosTemarios[currentCourse] ? todosLosTemarios[currentCourse] : [];
const isAcademicCourse = cursosCiencia.some((c) => c.id === currentCourse);
const urlPrefix = isAcademicCourse ? "/cursos" : "/apuntes";

const lessonData = selectedSyllabus.find((lesson: any) => lesson.id === lessonId);
const pageTitle = lessonData ? lessonData.titulo : frontmatter.titulo || "Clase Tyac";

const currentIndex = selectedSyllabus.findIndex((lesson: any) => lesson.id === lessonId);
const prevLesson = currentIndex > 0 ? selectedSyllabus[currentIndex - 1] : null;
const nextLesson = currentIndex !== -1 && currentIndex < selectedSyllabus.length - 1 ? selectedSyllabus[currentIndex + 1] : null;
---

<Layout titulo={`${pageTitle} - Tyac`}>
    <div class="studio-shell">
        
        <!-- SIDEBAR DE NAVEGACIÓN -->
        <SidebarVertical
            lecciones={selectedSyllabus}
            claseActualId={lessonId}
            cursoActualId={currentCourse}
        />

        <!-- ÁREA PRINCIPAL DEL ESTUDIO -->
        <main class="studio-main-viewport" transition:animate="fade">
            
            <!-- 01: ESCENARIO DE VIDEO -->
            <VideoStage 
                videoId={videoId} 
                pageTitle={pageTitle} 
                currentCourse={currentCourse} 
                urlPrefix={urlPrefix} 
                lessonData={lessonData}
                isAcademicCourse={isAcademicCourse}
            />

            <!-- 02: PANEL DE APUNTES INTERACTIVOS -->
            <TranscriptPane 
                frontmatter={frontmatter} 
                prevLesson={prevLesson} 
                nextLesson={nextLesson} 
                urlPrefix={urlPrefix} 
                currentCourse={currentCourse}
            >
                <slot />
            </TranscriptPane>

        </main>
    </div>
</Layout>

<style>
    /* Layout Framework */

    .studio-shell {
        display: flex;
        height: calc(100vh - 64px);
        background-color: var(--c-stage);
        overflow: hidden;
        width: 100%;
    }

    .studio-main-viewport {
        flex: 1;
        display: flex;
        height: 100%;
        min-width: 0;
    }

    @media (max-width: 1300px) {
        .studio-main-viewport {
            flex-direction: column;
            overflow-y: auto;
        }
    }
</style>

<script>
    /**
     * BULLETPROOF YOUTUBE ENGINE v3 (API Oficial)
     * Optimizada para contabilizar vistas reales en el canal de Youtube.
     */
    let player: any = null;
    let syncInterval: ReturnType<typeof setInterval> | null = null;
    let interactionToken = false;
    let currentVideoId: string | null = null;
    
    function startStudioSystem() {
        const playerDiv = document.getElementById('youtube-player-v3');
        if (!playerDiv) return;

        const videoId = playerDiv.getAttribute('data-video-id');
        if (!videoId || currentVideoId === videoId) return;

        if (syncInterval) clearInterval(syncInterval);
        player = null;
        currentVideoId = videoId;

        if (!document.querySelector('script[src*="iframe_api"]')) {
            const tag = document.createElement('script');
            tag.src = "https://www.youtube.com/iframe_api";
            document.body.appendChild(tag);
        }

        const injectPlayer = () => {
             if ((window as any).YT && (window as any).YT.Player) {
                player = new (window as any).YT.Player('youtube-player-v3', {
                    videoId: videoId,
                    playerVars: { 
                        'enablejsapi': 1, 
                        'origin': window.location.origin,
                        'modestbranding': 1,
                        'rel': 0,
                        'showinfo': 0,
                        'iv_load_policy': 3
                    },
                    events: {
                        'onReady': () => setupSync(),
                        'onStateChange': (e: { data: number }) => {
                            if (e.data === (window as any).YT.PlayerState.PLAYING) setupSync();
                            else stopSync();
                        }
                    }
                });
            } else {
                setTimeout(injectPlayer, 100);
            }
        };

        injectPlayer();
    }

    function setupSync() {
        if (syncInterval) clearInterval(syncInterval);
        syncInterval = setInterval(() => {
            if (player && typeof player.getCurrentTime === 'function') {
                const time = player.getCurrentTime();
                updateInteractiveNodes(time);
            }
        }, 500);
    }

    function stopSync() {
        if (syncInterval) clearInterval(syncInterval);
    }

    function updateInteractiveNodes(time: number) {
        const scroller = document.querySelector('.transcript-scroller');
        const nodes = Array.from(document.querySelectorAll('.sync-card')) as HTMLElement[];
        if (!nodes.length) return;

        // Auto-detect interaction
        if (scroller && !scroller.hasAttribute('data-init')) {
            scroller.addEventListener('mouseenter', () => interactionToken = true);
            scroller.addEventListener('mouseleave', () => interactionToken = false);
            scroller.setAttribute('data-init', 'true');
        }

        let activeNode: HTMLElement | null = null;
        for (const node of nodes) {
            const nodeTime = parseFloat(node.getAttribute('data-time') || '0');
            if (time >= nodeTime) activeNode = node;
        }

        if (activeNode && !activeNode.classList.contains('active')) {
            nodes.forEach(n => n.classList.remove('active'));
            activeNode.classList.add('active');
            
            if (!interactionToken) {
                activeNode.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }
    }

    // Interaction Listeners (Persistent)
    function attachListeners() {
        const nodes = document.querySelectorAll('.sync-card');
        nodes.forEach(node => {
            node.addEventListener('click', () => {
                const time = parseFloat(node.getAttribute('data-time') || '0');
                if (player && typeof player.seekTo === 'function') {
                    player.seekTo(time, true);
                    player.playVideo();
                }
            });
        });
    }

    document.addEventListener('astro:page-load', () => {
        startStudioSystem();
        attachListeners();
    });
</script>
