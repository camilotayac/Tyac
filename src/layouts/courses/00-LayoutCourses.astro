---
import Layout from "../head/00-Layout.astro";

const { frontmatter = {} } = Astro.props;
const videoId = Astro.props.videoId || frontmatter.videoId || "M7lc1UVf-VE";
const titulo = Astro.props.titulo || frontmatter.titulo || "Clase Tyac";
---

<Layout titulo={`${titulo} - Tyac`}>
    
    <div class="layout-container">
        <!-- Reproductor NATIVO, no le agregamos ningún estilo extra -->
        <div id="ytplayer" data-video-id={videoId}></div>

        <!-- Panel lateral para el texto -->
        <div class="transcript-pane">
            <slot />
        </div>
    </div>

    <style>
        .layout-container {
            display: flex;
            gap: 20px;
            /* Usamos alignItems flex-start para no alterar el iframe, y permitimos que crezca horizontalmente */
            align-items: flex-start;
            padding: 20px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .transcript-pane {
            /* Como fijaste el player a 600px de alto en JS, fijamos esto también a 600px para que calcen exacto */
            height: 600px;
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 15px;
            /* TRUCO: 250px de padding arriba y abajo para que la primera y la última tarjeta logren llegar justo al centro exacto */
            padding: 250px 10px;
        }

        .transcript-pane::-webkit-scrollbar {
            width: 8px;
        }
        .transcript-pane::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 4px;
        }

        /* DISEÑO DE LOS CUADROS BLANCOS */
        :global(.sync-card) {
            background: white;
            color: #1a1a2e;
            padding: 20px;
            border-radius: 8px;
            cursor: pointer;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); /* Transición más suave y majestuosa */
            opacity: 0.3; /* Cartas NO ACTIVAS son bastante transparentes/opacas */
            transform: scale(0.95);
        }

        :global(.sync-card:hover) {
            opacity: 0.8;
            transform: scale(0.98);
        }

        /* Estilo cuando el cuadro está activo (el video va por ahí) */
        :global(.sync-card.active) {
            opacity: 1 !important;
            border-left: 5px solid #7c4dff;
            transform: scale(1.05) !important; /* Se agranda en el centro */
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
            pointer-events: none; /* Evita que el usuario haga hover y arruine el efecto al que ya está activo */
        }

        :global(.sync-card h2), :global(.sync-card h3) {
            margin: 0 0 10px 0;
            font-size: 1.1rem;
        }

        :global(.sync-card p) {
            margin: 0;
            font-size: 0.95rem;
            line-height: 1.5;
        }
    </style>

    <script is:inline>
        var tag = document.createElement("script");
        tag.src = "https://www.youtube.com/player_api";
        var firstScriptTag = document.getElementsByTagName("script")[0];
        firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

        var player;
        var syncInterval;

        function onYouTubePlayerAPIReady() {
            var ytDiv = document.getElementById("ytplayer");
            var dynVideoId = ytDiv ? ytDiv.getAttribute("data-video-id") : "M7lc1UVf-VE";

            player = new YT.Player("ytplayer", {
                height: "600",
                width: "1000",
                videoId: dynVideoId,
                playerVars: {
                    autoplay: 0,
                    cc_lang_pref: "es",
                    cc_load_policy: 0,
                    color: "white",
                    controls: 0,
                    disablekb: 0,
                    enablejsapi: 1,
                    fs: 0,
                    hl: "es",
                    iv_load_policy: 3,
                    loop: 0,
                    playsinline: 1,
                    rel: 0,
                    start: 0,
                },
                events: {
                    'onReady': startTranscriptSync,
                    'onStateChange': function (event) {
                        if (event.data === YT.PlayerState.ENDED) {
                            player.seekTo(0);
                            player.stopVideo();
                        }
                    },
                },
            });
        }

        function startTranscriptSync() {
            var cards = document.querySelectorAll(".sync-card");

            // Evento Click
            cards.forEach(function (card) {
                card.addEventListener("click", function () {
                    var targetTime = parseInt(card.getAttribute("data-time"), 10);
                    if (!isNaN(targetTime) && player && player.seekTo) {
                        player.seekTo(targetTime, true);
                        player.playVideo();
                    }
                });
            });

            // Loop de Sincronización
            if (syncInterval) clearInterval(syncInterval);
            syncInterval = setInterval(function () {
                if (player && player.getCurrentTime) {
                    var currentTime = player.getCurrentTime();
                    var activeIndex = -1;

                    for (var i = 0; i < cards.length; i++) {
                        var cardTime = parseInt(cards[i].getAttribute("data-time"), 10);
                        if (cardTime <= currentTime) {
                            activeIndex = i;
                        } else {
                            break;
                        }
                    }

                    cards.forEach(function (card, i) {
                        if (i === activeIndex) {
                            if (!card.classList.contains("active")) {
                                card.classList.add("active");
                                card.scrollIntoView({ behavior: "smooth", block: "center" });
                            }
                        } else {
                            card.classList.remove("active");
                        }
                    });
                }
            }, 300);
        }
    </script>
</Layout>
