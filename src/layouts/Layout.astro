---
const { titulo, frontmatter } = Astro.props;
const tituloFinal = titulo || frontmatter?.titulo || "Tyac";
---

<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{tituloFinal}</title>

        <style>
            /* 🎨 VARIABLES DE COLOR MAGICAS */
            :root {
                --bg-page: #f4f4f9;
                --text-main: #334155;
                --header-bg: #1e293b;
                --text-header: #ffffff;
                --title-color: #0f172a;
                --card-bg: #ffffff;
                --border-color: #e2e8f0;
            }

            /* 🌙 COLORES PARA EL MODO OSCURO */
            html.dark {
                --bg-page: #0f172a; /* Azul muy oscuro */
                --text-main: #cbd5e1; /* Gris claro */
                --header-bg: #020617; /* Casi negro */
                --text-header: #f8fafc;
                --title-color: #f8fafc;
                --card-bg: #1e293b;
                --border-color: #334155;
            }

            /* Estilos del Buscador */
            .buscador-input {
                background-color: #334155 !important;
                color: white;
                border: 1px solid transparent;
                padding: 8px 16px;
                border-radius: 20px;
                outline: none;
                width: 180px;
                transition: all 0.3s ease;
                font-size: 14px;
            }

            .buscador-input:focus {
                width: 250px;
                background-color: #475569 !important;
                border-color: #3b82f6;
                box-shadow: 0 0 8px rgba(59, 130, 246, 0.4);
            }

            /* Botón del Tema */
            .btn-tema {
                background: none;
                border: none;
                font-size: 1.5rem;
                cursor: pointer;
                padding: 4px 8px;
                border-radius: 8px;
                transition: background-color 0.2s;
            }
            .btn-tema:hover {
                background-color: rgba(255, 255, 255, 0.1);
            }
        </style>

        <style is:global>
            /* Actualizamos el Markdown para que use las variables */
            .markdown-container {
                color: var(--text-main);
                line-height: 1.8;
                font-size: 1.1rem;
            }

            .markdown-container h1, 
            .markdown-container h2, 
            .markdown-container h3, 
            .markdown-container strong {
                color: var(--title-color);
            }

            .markdown-container h1 {
                border-bottom: 3px solid #3b82f6;
                padding-bottom: 0.5rem;
            }

            .markdown-container table {
                background-color: var(--card-bg);
                color: var(--text-main);
            }
            .markdown-container th {
                background-color: var(--border-color);
                color: var(--title-color);
            }
            .markdown-container td, .markdown-container th {
                border-color: var(--border-color);
            }
        </style>
    </head>

    <body style="font-family: system-ui, sans-serif; background-color: var(--bg-page); color: var(--text-main); margin: 0; transition: background-color 0.3s ease, color 0.3s ease;">
        
        <header style="background-color: var(--header-bg); color: var(--text-header); padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; transition: background-color 0.3s ease;">
            <div style="display: flex; align-items: center; gap: 24px;">
                <a href="/" style="color: var(--text-header); text-decoration: none; font-size: 24px; font-weight: bold;">
                    Tyac
                </a>
                <form action="/buscar" method="GET" id="buscador-principal" style="display: flex;">
                    <input type="text" name="q" id="q" placeholder="🔍 Buscar cursos..." class="buscador-input" required autocomplete="off" />
                    <button type="submit" style="display: none;">Buscar</button>
                </form>
            </div>

            <nav style="display: flex; align-items: center; gap: 24px;">
                <a href="/cursos" style="color: var(--text-header); text-decoration: none; font-weight: 500;">Cursos</a>
                <a href="/temas" style="color: var(--text-header); text-decoration: none; font-weight: 500;">Temas</a>
                
                <button id="theme-toggle" class="btn-tema" title="Cambiar tema oscuro/claro">
                    🌓
                </button>
            </nav>
        </header>

        <main class="markdown-container" style="max-width: 800px; margin: 0 auto; padding: 2rem;">
            <slot />
        </main>

<script>
    // Se ejecuta tan pronto como la página carga
    const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
        }
        return 'light';
    })();

    if (theme === 'dark') {
        document.documentElement.classList.add('dark');
    } else {
        document.documentElement.classList.remove('dark');
    }

    // Esperamos a que el botón exista en la pantalla para conectarlo
    document.addEventListener('DOMContentLoaded', () => {
        const toggleButton = document.getElementById("theme-toggle");
        
        if (toggleButton) {
            toggleButton.addEventListener("click", () => {
                document.documentElement.classList.toggle("dark");
                const isDark = document.documentElement.classList.contains("dark");
                localStorage.setItem("theme", isDark ? "dark" : "light");
            });
        }
    });
</script>
    </body>
</html>