---
// ============================================================
// src/layouts/Layout.astro — Layout base de toda la plataforma
// ============================================================
// Este es el "esqueleto" HTML que envuelve TODAS las páginas.
// Cualquier página que use <Layout> heredará el header y los estilos globales.
//
// CÓMO USARLO desde una página:
//   <Layout titulo="Mi Página">
//       <p>Mi contenido aquí</p>
//   </Layout>
//
// PROPS que acepta:
//   - titulo:      string — Texto que aparece en la pestaña del navegador.
//   - frontmatter: object — Se usa cuando lo llama un archivo .md (automático).

// Design tokens — variables de color globales (src/styles/tokens.css)
import "../styles/tokens.css";
import Buscador from "../components/Buscador.astro";
import SearchModal from "../components/SearchModal.astro";

const { titulo, frontmatter } = Astro.props;

// Determina el título final con este orden de prioridad:
//   1. El prop "titulo" (enviado desde páginas .astro)
//   2. frontmatter.titulo (cuando lo llama un .md directamente)
//   3. "Tyac" como valor por defecto si no se pasa nada
const tituloFinal = titulo || frontmatter?.titulo || "Tyac";
---

<!doctype html>
<html lang="es">
    <head>
        <!-- Codificación de caracteres: permite usar tildes y ñ -->
        <meta charset="utf-8" />

        <!-- Viewport: hace que la página se vea bien en celulares -->
        <!-- initial-scale=1 evita que iOS haga zoom automático -->
        <meta name="viewport" content="width=device-width, initial-scale=1" />

        <!-- Descripción que ven los buscadores (Google, etc.) -->
        <!-- Cambia este texto si quieres una descripción diferente en SEO -->
        <meta
            name="description"
            content="Tyac - Plataforma educativa para dominar ciencias a tu propio ritmo."
        />

        <!-- Título dinámico de la pestaña del navegador -->
        <title>{tituloFinal}</title>

        <!-- Fuente Inter desde Google Fonts -->
        <!-- "preconnect" acelera la descarga conectando antes de pedirla -->
        <!-- Pesos cargados: 400 (normal), 500 (medio), 600 (semibold), 700 (bold) -->
        <!-- Para agregar más pesos, añade :wght@400;500;600;700;900 etc. -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=SUSE:wght@400;500;600;700;800&display=swap"
            rel="stylesheet"
        />

        <!-- ================================================
             DESIGN TOKENS: Variables de color globales
             Editar en: src/styles/tokens.css
        ================================================ -->

        <style is:global>
            /* ================================================
               ESTILOS BASE DEL LAYOUT
               Los estilos de markdown están en src/styles/
            ================================================ */

            /* Arreglo para el 'rebote' (overscroll) en macOS/iOS.
               Pintamos el <html> con el color del header para que al
               estirar la página hacia arriba no se vea un fondo blanco. */
            html {
                background-color: var(--fondo-header);
            }

            body {
                min-height: 100vh;
            }
        </style>
    </head>

    <!-- BODY: Fuente principal + colores desde variables CSS -->
    <!-- Para cambiar la fuente global, cambia 'Inter' por otra (ej: 'Roboto') -->
    <body
        style="font-family: 'SUSE', system-ui, sans-serif; background-color: var(--bg-page); color: var(--text-main); margin: 0;"
    >
        <!-- ================================================
             HEADER — Barra superior de navegación
             ================================================
             Por ahora solo muestra el logo "Tyac".
             Si quieres agregar links de navegación, añádelos
             aquí dentro, por ejemplo:
               <nav>
                 <a href="/cursos">Cursos</a>
               </nav>
        ================================================ -->
        <header
            style="position: sticky; top: 0; z-index: 1000; background-color: var(--header-bg); color: var(--text-header); padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.1);"
        >
            <!-- Logo / nombre del sitio — clic lleva al inicio -->
            <div
                style="display: flex; align-items: center; gap: 20px; flex: 1;"
            >
                <a href="/" class="header-logo"> Tyac </a>

                <Buscador mode="header" />
            </div>

            <!-- Navegación derecha -->
            <nav style="display: flex; gap: 20px;">
                <a href="/#cursos" class="nav-link">Cursos</a>
                <a href="/#apuntes" class="nav-link">Apuntes</a>
            </nav>
        </header>

        <!-- ================================================
             MAIN — Contenido principal de cada página
             ================================================
             "max-width: 800px" limita el ancho para legibilidad.
             El <slot /> es donde se inyecta el contenido de
             la página que usa este layout.
             Si quieres más ancho, cambia el 800px.
        ================================================ -->
        <main>
            <slot />
        </main>

        <!-- Componente de Búsqueda Global -->
        <SearchModal />
    </body>
</html>

<style>
    /* Estilos para los links de navegación del header */
    .nav-link {
        color: var(--acento); /* Color púrpura del tema */
        text-decoration: none;
        font-weight: 600;
        font-size: 20px;
        opacity: 0.9;
        transition: all 0.2s ease;
        padding: 5px 10px;
        border-radius: 8px;
    }

    .nav-link:hover {
        opacity: 1;
        background-color: var(--overlay-hover);
        transform: translateY(-1px);
    }

    /* Ajuste para el logo Tyac para que sea coherente */
    .header-logo {
        color: var(--text-header);
        text-decoration: none;
        font-size: 30px;
        font-weight: 700;
        letter-spacing: -0.5px;
        transition: color 0.2s ease;
    }

    .header-logo:hover {
        color: var(--acento);
    }
</style>
