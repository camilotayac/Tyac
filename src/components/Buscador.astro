---
// src/components/Buscador.astro
interface Props {
    mode?: "hero" | "header";
}

const { mode = "hero" } = Astro.props;
---

<div class={`buscador-global-container ${mode}`} data-buscador>
    <div class="buscador-inner">
        <input
            type="text"
            placeholder={mode === "hero"
                ? "Ej. JavaScript, Física, Astro..."
                : "Buscar..."}
            class="buscador-input"
            readonly={mode === "hero"}
            autocomplete="off"
            aria-label="Buscar contenidos"
            data-input
        />
        <span class="buscador-icono">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
        </span>

        {/* PANEL DE RESULTADOS (Solo para modo header) */}
        {mode === "header" && (
            <div class="panel-resultados" hidden data-panel>
                <div class="lista-resultados" data-lista></div>
                <div class="sin-resultados" hidden data-sin-resultados>
                    No hay resultados.
                </div>
            </div>
        )}
    </div>
</div>

<style>
    .buscador-global-container {
        position: relative;
        width: 100%;
    }

    .buscador-inner {
        position: relative;
        width: 100%;
        background: #1e1f29;
        border: 2px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        display: flex;
        align-items: center;
    }

    .hero .buscador-inner {
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        cursor: pointer;
    }

    .hero .buscador-inner:hover {
        border-color: var(--dracula-purple) !important;
        background: #282a36 !important;
        transform: translateY(-6px) scale(1.03) !important;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(189, 147, 249, 0.4) !important;
        z-index: 20;
    }

    .buscador-input {
        width: 100%;
        padding: 1rem 3rem 0.8rem 1.2rem;
        font-size: 0.95rem;
        color: var(--clr-white-soft);
        background: transparent;
        border: none;
        outline: none;
    }

    .hero .buscador-input { pointer-events: none; }

    .buscador-icono {
        position: absolute;
        right: 1.2rem;
        width: 20px;
        height: 20px;
        color: var(--clr-gray-muted);
    }

    /* Ajustes específicos HEADER */
    .header {
        max-width: 420px;
        flex: 1;
    }

    .header .buscador-inner {
        padding: 0;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(30, 31, 41, 0.5);
    }

    .header .buscador-input {
        padding: 0.5rem 2.8rem 0.55rem 1.2rem;
        font-size: 0.9rem;
    }

    .header .buscador-icono {
        width: 16px;
        height: 16px;
        right: 0.8rem;
    }

    /* PANEL DE RESULTADOS HEADER */
    .panel-resultados {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        right: 0;
        background: rgba(30, 31, 41, 0.95);
        backdrop-filter: blur(15px);
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
        max-height: 400px;
        overflow-y: auto;
        z-index: 1000;
        padding: 8px;
    }

    .sin-resultados {
        padding: 20px;
        color: var(--clr-gray-muted);
        text-align: center;
        font-size: 0.85rem;
    }
</style>

<style is:global>
    /* =========================================
       ESTILOS DE RESULTADOS UNIVERSALES
       ========================================= */
    .item-resultado {
        padding: 10px;
        border-radius: 12px;
        color: var(--clr-white-soft) !important;
        text-decoration: none !important;
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 12px;
        align-items: center;
        transition: all 0.2s ease;
        margin-bottom: 4px;
    }

    .item-resultado:hover {
        background: rgba(255, 255, 255, 0.05);
        transform: translateX(4px);
    }

    .res-icono-box {
        width: 40px;
        height: 40px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .res-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
    }

    .res-titulo {
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--clr-white-soft);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .res-meta {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .res-tipo {
        font-size: 0.55rem;
        text-transform: uppercase;
        font-weight: 800;
        padding: 2px 6px;
        border-radius: 4px;
    }

    /* Colores por Materia */
    .materia-matematicas { background: var(--dracula-purple); color: #191a21 !important; }
    .materia-tecnologia { background: var(--dracula-cyan); color: #191a21 !important; }
    .materia-quimica { background: var(--dracula-red); color: #ffffff !important; }
    .materia-biologia { background: var(--dracula-green); color: #191a21 !important; }
    .materia-general { background: var(--clr-gray-muted); color: #191a21 !important; }

    .res-snippet {
        font-size: 0.8rem;
        color: var(--clr-gray-muted);
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
        opacity: 0.7;
    }
</style>

<script>
    declare global {
        interface Window {
            buscadorInitialized: boolean;
        }
    }

    import { normalize, calculateScore } from "../utils/search.js";

    interface SearchItem {
        titulo: string;
        descripcion: string;
        url: string;
        materia: string;
        tipo: string;
        icono: string;
    }

    let searchData: SearchItem[] = [];

    async function fetchData() {
        if (searchData.length > 0) return searchData;
        const res = await fetch("/api/buscador.json");
        searchData = await res.json();
        return searchData;
    }

    function initHybridBuscador() {
        const containers = document.querySelectorAll("[data-buscador]");
        
        containers.forEach(container => {
            const isHero = container.classList.contains("hero");
            const input = container.querySelector("[data-input]") as HTMLInputElement;
            const panel = container.querySelector("[data-panel]") as HTMLElement;
            const lista = container.querySelector("[data-lista]") as HTMLElement;
            const sinRes = container.querySelector("[data-sin-resultados]") as HTMLElement;

            // Limpiar listeners previos (especialmente para persiste)
            const newContainer = container.cloneNode(true);
            container.parentNode?.replaceChild(newContainer, container);
            
            // Re-obtener referencias tras el clon
            const activeContainer = newContainer as HTMLElement;
            const activeInput = activeContainer.querySelector("[data-input]") as HTMLInputElement;
            const activePanel = activeContainer.querySelector("[data-panel]") as HTMLElement;
            const activeLista = activeContainer.querySelector("[data-lista]") as HTMLElement;
            const activeSinRes = activeContainer.querySelector("[data-sin-resultados]") as HTMLElement;

            if (isHero) {
                // MODO HERO: Disparador del modal
                activeContainer.addEventListener("click", (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    window.dispatchEvent(new CustomEvent("open-search"));
                });
            } else {
                function getIconSvg(nombre: string) {
                    const svgs: Record<string, string> = {
                        "quimica": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a2 2 0 0 0 1.78 2.95h11a2 2 0 0 0 1.78-2.95l-5.068-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/><path d="M7 16h10"/></svg>`,
                        "astro": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 3.82-13 1.5 1.5 0 0 0-2.18-2 22 22 0 0 0-13 3.82 1.5 1.5 0 0 0-2 2.18A22 22 0 0 0 4.18 18.5a1.5 1.5 0 0 0 2 2.18A22 22 0 0 1 19.18 21a1.5 1.5 0 0 0 2.18-2 22 22 0 0 0-3.82-13l-3 3"/><path d="m14.5 13.5-3-3"/></svg>`,
                        "general": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" x2="12" y1="22" y2="12"/></svg>`
                    };
                    return svgs[nombre] || (nombre && nombre.length < 4 ? nombre : svgs["general"]);
                }

                // MODO HEADER: Búsqueda local
                activeInput?.addEventListener("input", async (e) => {
                    const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
                    if (query.length < 2) {
                        if (activePanel) activePanel.setAttribute("hidden", "");
                        return;
                    }

                    const data = await fetchData();
                    const resultsWithScore = data.map(item => ({
                        item,
                        score: calculateScore(query, item)
                    }))
                    .filter(res => res.score > 15)
                    .sort((a, b) => b.score - a.score)
                    .slice(0, 7);

                    const results = resultsWithScore.map(res => res.item);

                    if (activePanel && activeLista) {
                        activePanel.removeAttribute("hidden");
                        activeLista.innerHTML = "";
                        
                        if (results.length > 0) {
                            activeSinRes?.setAttribute("hidden", "");
                            results.forEach(item => {
                                const a = document.createElement("a");
                                a.href = item.url;
                                a.className = "item-resultado";
                                a.innerHTML = `
                                    <div class="res-icono-box">${getIconSvg(item.icono)}</div>
                                    <div class="res-info">
                                        <div class="res-titulo">${item.titulo}</div>
                                        <div class="res-meta">
                                            <span class="res-tipo materia-${item.materia.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "")}">${item.materia}</span>
                                            <span class="res-subtipo">${item.tipo === "curso" ? "Curso" : "Clase"}</span>
                                        </div>
                                    </div>
                                `;
                                
                                // Limpiar buscador al hacer clic en un resultado
                                a.addEventListener("click", () => {
                                    activeInput.value = "";
                                    activePanel?.setAttribute("hidden", "");
                                });
                                
                                activeLista.appendChild(a);
                            });
                        } else {
                            activeSinRes?.removeAttribute("hidden");
                        }
                    }
                });

                document.addEventListener("click", (e) => {
                    if (!activeContainer.contains(e.target as Node)) {
                        activePanel?.setAttribute("hidden", "");
                    }
                });
            }
        });
    }

    // Inicialización coordinada
    if (!window.buscadorInitialized) {
        initHybridBuscador();
        window.buscadorInitialized = true;
    }
    document.addEventListener("astro:page-load", initHybridBuscador);
</script>
