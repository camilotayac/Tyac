---
// src/components/Buscador.astro
interface Props {
    mode?: "hero" | "header";
}

const { mode = "hero" } = Astro.props;
---

<div class={`buscador-global-container ${mode}`} data-buscador>
    <div class="buscador-inner">
        <input
            type="text"
            placeholder={mode === "hero"
                ? "Ej. JavaScript, Física, Astro..."
                : "Buscar..."}
            class="buscador-input"
            autocomplete="off"
            aria-label="Buscar contenidos"
            aria-expanded="false"
            data-input
        />
        <span class="buscador-icono">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
        </span>

        <!-- PANEL DE RESULTADOS DINÁMICO -->
        <div class="panel-resultados" hidden role="listbox" data-panel>
            <div class="lista-resultados" data-lista></div>
            <div class="sin-resultados" hidden data-sin-resultados>
                No encontramos resultados para esa búsqueda.
            </div>
        </div>
    </div>
</div>

<style>
    /* ══════════════════════════════════════════════
       DISEÑO UNIVERSAL (Premium & Unificado)
       ══════════════════════════════════════════════ */
    .buscador-global-container {
        position: relative;
        width: 100%;
    }

    .buscador-inner {
        position: relative;
        width: 100%;
        background: #1e1f29;
        border: 2px solid rgba(255, 255, 255, 0.05);
        border-radius: 10px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow:
            0 10px 30px rgba(0, 0, 0, 0.3),
            inset 0 1px 1px rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
    }

    .buscador-inner:focus-within {
        background: #282a36;
        border-color: var(--acento);
        box-shadow:
            0 0 0 4px rgba(189, 147, 249, 0.1),
            0 15px 40px rgba(0, 0, 0, 0.4);
        transform: translateY(-2px);
    }

    .buscador-input {
        width: 100%;
        padding: 1rem 3rem 0.8rem 1.2rem;
        font-size: 0.95rem;
        color: var(--texto-claro);
        background: transparent;
        border: none;
        outline: none;
    }

    .buscador-icono {
        position: absolute;
        right: 0.8rem;
        width: 20px;
        height: 20px;
        color: var(--texto-atenuado);
        pointer-events: none;
        transition: all 0.3s ease;
    }

    /* Ajustes específicos de ubicación */
    .hero {
        max-width: 100%;
    }

    .header {
        max-width: 420px;
        flex: 1;
    }

    .header .buscador-inner {
        padding: 0;
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: none;
        background: rgba(30, 31, 41, 0.5);
    }

    .header .buscador-inner:focus-within {
        border-color: #ffffff;
        box-shadow: 0 0 0 1px #ffffff;
        transform: none;
        background: rgba(40, 42, 54, 0.8);
    }

    .header .buscador-input {
        padding: 0.5rem 2.8rem 0.55rem 1.2rem;
        font-size: 0.9rem;
    }

    .header .buscador-icono {
        width: 16px;
        height: 16px;
        right: 0.7rem;
    }

    .header .buscador-icono {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        width: 14px;
        height: 14px;
        color: var(--texto-atenuado);
    }

    /* ══════════════════════════════════════════════
       PANEL DE RESULTADOS (Dropdown)
       ══════════════════════════════════════════════ */
    .panel-resultados {
        position: absolute;
        top: calc(100% + 12px);
        left: 0;
        right: 0;
        background: rgba(30, 31, 41, 0.98);
        backdrop-filter: blur(20px);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
        max-height: 480px;
        overflow-y: auto;
        z-index: 2000;
        padding: 10px;
    }

    .header .panel-resultados {
        width: 400px;
        right: 0;
        left: auto;
    }

    .sin-resultados {
        padding: 30px;
        color: var(--texto-atenuado);
        font-style: italic;
        text-align: center;
        font-size: 0.95rem;
    }
</style>

<style is:global>
    /* =========================================
       ESTILOS DE RESULTADOS (Globales)
       ========================================= */
    .item-resultado {
        padding: 12px;
        border-radius: 14px;
        color: var(--texto-claro) !important;
        text-decoration: none !important;
        display: grid;
        grid-template-columns: 48px 1fr;
        gap: 12px;
        align-items: center;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        margin-bottom: 4px;
    }

    .item-resultado:hover {
        background: linear-gradient(
            90deg,
            rgba(189, 147, 249, 0.1) 0%,
            transparent 100%
        );
        transform: translateX(4px);
    }

    .res-icono-box {
        width: 48px;
        height: 48px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .res-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .res-titulo {
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--texto-claro);
        line-height: 1.2;
    }

    .res-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 2px;
    }

    .res-tipo {
        font-size: 0.6rem;
        text-transform: uppercase;
        font-weight: 800;
        padding: 2px 8px;
        border-radius: 6px;
    }

    .res-subtipo {
        font-size: 0.65rem;
        color: var(--texto-atenuado);
        background: rgba(255, 255, 255, 0.05);
        padding: 2px 6px;
        border-radius: 4px;
    }

    .materia-matematicas {
        background: var(--dracula-purple);
        color: #191a21 !important;
    }
    .materia-tecnologia {
        background: var(--dracula-cyan);
        color: #191a21 !important;
    }
    .materia-quimica {
        background: var(--dracula-red);
        color: #ffffff !important;
    }
    .materia-biologia {
        background: var(--dracula-green);
        color: #191a21 !important;
    }
    .materia-general {
        background: var(--texto-atenuado);
        color: #191a21 !important;
    }

    .res-snippet {
        font-size: 0.85rem;
        color: var(--texto-atenuado);
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<script>
    interface SearchItem {
        titulo: string;
        descripcion: string;
        url: string;
        materia: string;
        tipo: string;
        icono: string;
        curso?: string;
    }

    let searchData: SearchItem[] = [];
    let isLoadingData = false;

    async function fetchData(): Promise<SearchItem[]> {
        if (searchData.length > 0) return searchData;
        if (isLoadingData) {
            return new Promise((resolve) => {
                const check = () => {
                    if (searchData.length > 0) resolve(searchData);
                    else setTimeout(check, 50);
                };
                check();
            });
        }

        isLoadingData = true;
        try {
            const res = await fetch("/api/buscador.json");
            if (!res.ok) throw new Error("Error fetching search data");
            const json = await res.json();
            searchData = Array.isArray(json) ? json : [];
            return searchData;
        } catch (e) {
            console.error("Buscador error:", e);
            return [];
        } finally {
            isLoadingData = false;
        }
    }

    function initBuscador() {
        const containers = document.querySelectorAll("[data-buscador]");

        containers.forEach((container) => {
            const input = container.querySelector("[data-input]");
            const panel = container.querySelector("[data-panel]");
            const lista = container.querySelector("[data-lista]");
            const sinRes = container.querySelector("[data-sin-resultados]");

            if (
                !(input instanceof HTMLInputElement) ||
                !(panel instanceof HTMLElement) ||
                !(lista instanceof HTMLElement) ||
                !(sinRes instanceof HTMLElement)
            )
                return;

            // Carga proactiva al hacer focus
            input.addEventListener("focus", () => fetchData());

            input.addEventListener("input", async (e) => {
                const target = e.target;
                if (!(target instanceof HTMLInputElement)) return;

                const query = target.value.toLowerCase().trim();
                if (query.length < 2) {
                    panel.style.display = "none";
                    return;
                }

                const data = await fetchData();
                const terms = query.split(" ").filter((t) => t.length > 0);

                const results = data
                    .map((item) => {
                        let score = 0;
                        const titulo = (item.titulo || "").toLowerCase();
                        const desc = (item.descripcion || "").toLowerCase();
                        const materia = (item.materia || "").toLowerCase();
                        const curso = (item.curso || "").toLowerCase();

                        const matchesAll = terms.every(
                            (t) =>
                                titulo.includes(t) ||
                                desc.includes(t) ||
                                materia.includes(t) ||
                                curso.includes(t),
                        );

                        if (!matchesAll) return { item, score: 0 };

                        terms.forEach((t) => {
                            if (titulo.includes(t)) score += 150;
                            if (desc.includes(t)) score += 40;
                            if (materia.includes(t)) score += 20;
                        });

                        return { item, score };
                    })
                    .filter((res) => res.score > 0)
                    .sort((a, b) => b.score - a.score)
                    .slice(0, 8);

                lista.innerHTML = "";
                panel.style.display = "block";
                panel.removeAttribute("hidden");

                if (results.length > 0) {
                    sinRes.style.display = "none";
                    results.forEach(({ item }) => {
                        const materiaStr = item.materia || "general";
                        const classMat = `materia-${materiaStr
                            .toLowerCase()
                            .normalize("NFD")
                            .replace(/[\u0300-\u036f]/g, "")}`;

                        const a = document.createElement("a");
                        a.href = item.url;
                        a.className = "item-resultado";
                        a.innerHTML = `
                            <div class="res-icono-box">${item.icono || "📄"}</div>
                            <div class="res-info">
                                <div class="res-meta">
                                    <span class="res-tipo ${classMat}">${materiaStr}</span>
                                    <span class="res-subtipo">${item.tipo === "curso" ? "Curso" : "Clase"}</span>
                                </div>
                                <div class="res-titulo">${item.titulo}</div>
                                <div class="res-snippet">${item.descripcion}</div>
                            </div>
                        `;
                        lista.appendChild(a);
                    });
                } else {
                    sinRes.style.display = "block";
                    sinRes.removeAttribute("hidden");
                }
            });

            // Cerrar al hacer clic fuera
            const closePanel = (e: MouseEvent) => {
                if (e.target instanceof Node && !container.contains(e.target)) {
                    panel.style.display = "none";
                }
            };
            document.addEventListener("click", closePanel);
        });
    }

    // Inicialización compatible con View Transitions
    initBuscador();
    document.addEventListener("astro:page-load", initBuscador);
</script>
