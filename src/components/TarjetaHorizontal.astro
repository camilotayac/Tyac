---
// src/components/TarjetaHorizontal.astro
export interface Props {
    titulo: string;
    descripcion?: string;
    icono: string;
    cantidadTemas: string;
}

import IconoElegante from "./IconoElegante.astro";

const { titulo, descripcion, icono, cantidadTemas } = Astro.props;
---

<div class="tarjeta-platzi">
    <div class="cuerpo-superior">
        <div class="icono-contenedor">
            <IconoElegante nombre={icono} class="icono-tarjeta" size="3.5rem" />
        </div>
        <div class="info-contenedor">
            <h3>{titulo}</h3>
            {descripcion && <p>{descripcion}</p>}
        </div>
    </div>
    <div class="pie-inferior">
        <IconoElegante nombre="clases" size="16px" />
        <span>{cantidadTemas} {cantidadTemas === "1" ? "tema" : "temas"}</span>
        <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="chevron"
        >
            <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
    </div>
</div>

<style>
    .tarjeta-platzi {
        background-color: var(
            --bg-tarjetas
        ); /* Fondo dedicado para tarjetas */
        border-radius: 16px;
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease,
            border-color 0.2s ease;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid transparent;
        cursor: pointer;
        /* Sombra flotante base */
        box-shadow: var(--shd-card);
    }

    /* Efecto al hacer hover (pasar el mouse) */
    .tarjeta-platzi:hover {
        transform: translateY(-4px);
        box-shadow: var(--shd-hover);
        border-color: var(--dracula-purple); /* Acento púrpura */
    }

    .cuerpo-superior {
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .icono-contenedor {
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #bd93f9; /* Color estricto para máxima visibilidad */
        background-color: rgba(189, 147, 249, 0.05);
        border-radius: 12px;
    }

    .info-contenedor h3 {
        margin: 0;
        font-size: 1.5rem;
        color: var(--clr-white-soft); /* Semántico para tarjetas */
        font-weight: 700;
        letter-spacing: -0.5px;
    }

    .info-contenedor p {
        margin: 0.5rem 0 0 0;
        font-size: 0.95rem;
        color: var(--clr-gray-muted); /* Semántico para tarjetas */
        line-height: 1.4;
    }

    .pie-inferior {
        background-color: var(
            --bg-sidebar
        ); /* Background diferente (más bajito) para el footer */
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border-top: 1px solid var(--clr-gray-border);
    }

    .pie-inferior span {
        font-size: 0.95rem;
        font-weight: 700;
        color: #0284c7; /* Azul más oscuro y legible como pidió el usuario */
    }

    .pie-inferior :global(svg) {
        color: #0284c7;
    }

    .chevron {
        width: 18px;
        height: 18px;
        color: var(--dracula-cyan);
        margin-top: 2px;
    }
</style>
