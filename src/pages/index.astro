---
import Layout from "../layouts/Layout.astro";
import TarjetaCurso from "../components/TarjetaCurso.astro";
---

<Layout titulo="Tyac - Plataforma Educativa">
	<div
		style="max-width: 900px; margin: 0 auto; background: white; padding: 2.5rem; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.1);"
	>
		<h1 style="color: #2c3e50; font-size: 2.5rem; margin-bottom: 0.5rem;">
			Bienvenido a Tyac 🔬
		</h1>
		<p style="font-size: 1.2rem; color: #666; margin-bottom: 2rem;">
			Domina la ciencia a tu propio ritmo. Explora nuestras guías
			estructuradas.
		</p>

		<div
			style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;"
		>
			<TarjetaCurso
				titulo="Química Computacional"
				descripcion="Aprende las bases teóricas y herramientas in silico para el análisis molecular."
				icono="💻"
			/>
			<TarjetaCurso
				titulo="Dinámica Molecular"
				descripcion="Simulaciones y análisis de trayectorias con herramientas como GROMACS y Python."
				icono="⚛️"
			/>
			<TarjetaCurso
				titulo="Fisiología Vegetal"
				descripcion="Estudio de estructuras celulares y su comportamiento a nivel biofísico."
				icono="🌱"
			/>
		</div>
	</div>
</Layout>
