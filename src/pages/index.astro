---
import Layout from "../layouts/Layout.astro";
import TarjetaHorizontal from "../components/TarjetaHorizontal.astro";
import BotonMateria from "../components/BotonMateria.astro";
import Buscador from "../components/Buscador.astro";
import { todosLosTemarios } from "../data/temarios.js";

// Lista de Cursos (Materias académicas)
const cursosCiencia = [
    {
        titulo: "Matemáticas: Conjuntos",
        descripcion:
            "Lógica proposicional, unión, intersección y teoría de conjuntos.",
        icono: "🔢",
        materia: "Matemáticas",
        href: "/apuntes/conjuntos/proposicion",
        lecciones: todosLosTemarios.conjuntos.length,
    },
    {
        titulo: "Química Orgánica",
        descripcion:
            "Introducción a los hidrocarburos, enlaces y estructuras moleculares.",
        icono: "🧪",
        materia: "Química",
        href: "#",
        lecciones: 12,
    },
    {
        titulo: "Biología Celular",
        descripcion:
            "Estudio de la célula, orgánulos y procesos metabólicos básicos.",
        icono: "🧬",
        materia: "Biología",
        href: "#",
        lecciones: 10,
    },
    {
        titulo: "Física Mecánica",
        descripcion: "Leyes de Newton, cinemática y dinámica de partículas.",
        icono: "🎡",
        materia: "Física",
        href: "#",
        lecciones: 15,
    },
];

// Lista de Apuntes (Tecnología y herramientas)
const apuntesTecnicos = [
    {
        titulo: "Guía de Astro",
        descripcion:
            "Aprende a crear sitios web rápidos y modernos con Astro desde cero.",
        icono: "🚀",
        materia: "Astro",
        href: "/apuntes/astro/introduccion",
        lecciones: todosLosTemarios.astro.length,
    },
    {
        titulo: "JavaScript Moderno",
        descripcion: "Domina ES6+, callbacks, promesas y async/await.",
        icono: "🟨",
        materia: "JavaScript",
        href: "#",
        lecciones: 15,
    },
    {
        titulo: "Node.js Backend",
        descripcion:
            "Construye APIs escalables con Express y bases de datos NoSQL.",
        icono: "🟢",
        materia: "Node.js",
        href: "#",
        lecciones: 20,
    },
    {
        titulo: "Docker para Devs",
        descripcion: "Contenedores, imágenes y despliegue continuo.",
        icono: "🐳",
        materia: "Docker",
        href: "#",
        lecciones: 9,
    },
    {
        titulo: "Git & GitHub",
        descripcion:
            "Control de versiones, flujo de ramas y colaboración en equipo.",
        icono: "🐙",
        materia: "Git",
        href: "#",
        lecciones: 5,
    },
];
---

<Layout titulo="Tyac - Plataforma Educativa">
    <!-- SECCIÓN HERO (Estilo Platzi) -->
    <div class="hero-platzi">
        <!-- Elementos decorativos flotantes -->
        <div class="decoracion" style="top: 15%; left: 8%; animation-delay: 0s;">🧬</div>
        <div class="decoracion" style="bottom: 25%; right: 7%; animation-delay: -7s;">⚛️</div>
        <div class="decoracion" style="top: 35%; right: 12%; animation-delay: -3s; font-size: 2rem;">🚀</div>
        <div class="decoracion" style="bottom: 15%; left: 12%; animation-delay: -12s; font-size: 2.2rem;">🧪</div>
        <div class="decoracion" style="top: 20%; right: 25%; animation-delay: -5s; font-size: 1.8rem;">🌿</div>
        <div class="decoracion" style="bottom: 40%; left: 5%; animation-delay: -9s; font-size: 1.5rem;">💻</div>
        <div class="decoracion" style="top: 10%; right: 40%; animation-delay: -15s; font-size: 1.2rem;">👾</div>
        <div class="decoracion" style="bottom: 10%; right: 35%; animation-delay: -2s; font-size: 1.6rem;">🌍</div>

        <div class="hero-contenido">
            <h1 class="hero-titulo">
                La biblioteca de conocimiento <br />
                <span class="hero-acento">de Ciencias y Tecnología</span>
            </h1>
            <p class="hero-subtitulo">
                Aprende conceptos complejos de forma sencilla, rápida y
                organizada.
            </p>
            <p class="hero-pregunta">¿Qué quieres aprender hoy?</p>

            <div class="hero-buscador">
                <Buscador mode="hero" />
            </div>
        </div>
    </div>

    <!-- CONTENEDOR PRINCIPAL -->
    <div class="contenedor-layout">
        {/* SECCIÓN CURSOS */}
        {
            cursosCiencia.length > 0 && (
                <section class="seccion-grid" id="cursos">
                    <div class="info-sticky">
                        <h2 class="titulo-seccion">
                            <span class="icono-seccion">📚</span> Cursos
                        </h2>
                        <p class="desc-seccion">
                            Explora nuestra lista de materias enfocadas en las
                            ciencias exactas. Aprende a tu propio ritmo con
                            contenido estructurado y de alta calidad.
                        </p>
                        <div class="contenedor-pildoras">
                            <BotonMateria 
                                texto="General" 
                                tipo="gris" 
                                data-filter="all" 
                                class="filtro-btn activo"
                            />
                            <BotonMateria
                                texto="Matemáticas"
                                tipo="purpura"
                                data-filter="Matemáticas"
                                class="filtro-btn"
                            />
                            <BotonMateria 
                                texto="Química" 
                                tipo="rojo" 
                                data-filter="Química"
                                class="filtro-btn"
                            />
                            <BotonMateria 
                                texto="Biología" 
                                tipo="verde" 
                                data-filter="Biología"
                                class="filtro-btn"
                            />
                            <BotonMateria 
                                texto="Física" 
                                tipo="amarillo" 
                                data-filter="Física"
                                class="filtro-btn"
                            />
                        </div>
                    </div>
                    <div class="contenido-scroll">
                        <div class="grid-tarjetas">
                            {cursosCiencia.map((curso) => (
                                <a
                                    href={curso.href}
                                    style="text-decoration: none; color: inherit; transition: all 0.3s ease;"
                                    data-materia={curso.materia}
                                    class="tarjeta-link"
                                >
                                    <TarjetaHorizontal
                                        titulo={curso.titulo}
                                        descripcion={curso.descripcion}
                                        icono={curso.icono}
                                        cantidadTemas={String(curso.lecciones)}
                                    />
                                </a>
                            ))}
                        </div>
                    </div>
                </section>
            )
        }

        {/* SECCIÓN APUNTES */}
        <section class="seccion-grid invertida" id="apuntes">
            <div class="contenido-scroll">
                <div class="grid-tarjetas">
                    {
                        apuntesTecnicos.map((apunte) => (
                            <a
                                href={apunte.href}
                                style="text-decoration: none; color: inherit; transition: all 0.3s ease;"
                                data-materia={apunte.materia}
                                class="tarjeta-link"
                            >
                                <TarjetaHorizontal
                                    titulo={apunte.titulo}
                                    descripcion={apunte.descripcion}
                                    icono={apunte.icono}
                                    cantidadTemas={String(apunte.lecciones)}
                                />
                            </a>
                        ))
                    }
                </div>
            </div>
            <div class="info-sticky">
                <h2 class="titulo-seccion">
                    <span class="icono-seccion">📝</span> Apuntes
                </h2>
                <p class="desc-seccion">
                    Guías de desarrollo, documentación tecnológica y resúmenes
                    sobre herramientas modernas. Todo lo que necesitas para tu
                    carrera técnica en un solo lugar.
                </p>
                <div class="contenedor-pildoras">
                    <BotonMateria 
                        texto="General" 
                        tipo="gris" 
                        data-filter="all" 
                        class="filtro-btn activo"
                    />
                    <BotonMateria
                        texto="Astro"
                        tipo="purpura"
                        data-filter="Astro"
                        class="filtro-btn"
                    />
                    <BotonMateria 
                        texto="Docker" 
                        tipo="gris" 
                        data-filter="Docker"
                        class="filtro-btn"
                    />
                    <BotonMateria 
                        texto="JavaScript" 
                        tipo="rojo" 
                        data-filter="JavaScript"
                        class="filtro-btn"
                    />
                    <BotonMateria 
                        texto="Node.js" 
                        tipo="verde" 
                        data-filter="Node.js"
                        class="filtro-btn"
                    />
                    <BotonMateria 
                        texto="Git" 
                        tipo="amarillo" 
                        data-filter="Git"
                        class="filtro-btn"
                    />
                </div>
            </div>
        </section>
    </div>
</Layout>

<style>
    /* =========================================
       HERO SECTION
       ========================================= */
    .hero-platzi {
        position: relative;
        overflow: hidden;
        background-color: var(--fondo-pagina);
        background-image: var(--fondo-hero-glow);
        color: var(--texto-claro);
        padding: 12rem 2rem 4rem 2rem; /* Reducido abajo para compensar el layout */
        text-align: center;
    }

    /* Blobs de fondo (Mesh effect) */
    .hero-platzi::before,
    .hero-platzi::after {
        content: '';
        position: absolute;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        filter: blur(80px);
        z-index: 0;
        opacity: 0.4;
        animation: float-slow 20s infinite alternate;
    }

    .hero-platzi::before {
        background: var(--acento);
        top: -100px;
        left: -100px;
    }

    .hero-platzi::after {
        background: var(--dracula-cyan);
        bottom: -150px;
        right: -100px;
        animation-delay: -5s;
    }

    @keyframes float-slow {
        from { transform: translate(0, 0) scale(1); }
        to { transform: translate(50px, 50px) scale(1.1); }
    }

    .hero-contenido {
        position: relative;
        z-index: 10;
        max-width: 900px;
        margin: 0 auto;
    }

    .hero-titulo {
        font-size: 4.5rem;
        font-weight: 900;
        line-height: 1.05;
        margin-bottom: 3.5rem; /* Más espacio bajo el título */
        letter-spacing: -2px;
        animation: reveal-up 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .hero-acento {
        background: linear-gradient(135deg, var(--acento) 0%, var(--dracula-cyan) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: inline-block;
    }

    .hero-subtitulo {
        font-size: 1.25rem;
        color: var(--texto-atenuado);
        margin-bottom: 4.5rem; /* Más espacio bajo el subtítulo */
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.6;
        text-wrap: balance;
        opacity: 0;
        animation: reveal-up 1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    }

    .hero-pregunta {
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--acento);
        margin-bottom: 3rem; /* Más espacio bajo la pregunta */
        opacity: 0;
        animation: reveal-up 1s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
    }

    .hero-buscador {
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
        opacity: 0;
        animation: reveal-up 1s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
        filter: drop-shadow(0 0 20px rgba(189, 147, 249, 0.2));
    }

    @keyframes reveal-up {
        from {
            opacity: 0;
            transform: translateY(30px);
            filter: blur(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
            filter: blur(0);
        }
    }

    /* Elementos flotantes decorativos */
    .decoracion {
        position: absolute;
        font-size: 3rem;
        opacity: 0.2;
        user-select: none;
        pointer-events: none;
        animation: orbit 15s infinite linear;
    }

    @keyframes orbit {
        from { transform: rotate(0deg) translateX(50px) rotate(0deg); }
        to { transform: rotate(360deg) translateX(50px) rotate(-360deg); }
    }
</style>

<style>
    /* =========================================
       LAYOUT DE SECCIONES GRID (Sticky)
       ========================================= */
    .contenedor-layout {
        max-width: 100%;
        margin: 0 auto;
        padding: 8rem 5% 12rem 5%; /* Ajustado a 10rem */
        display: flex;
        flex-direction: column;
        gap: 8rem; /* Ajustado a 10rem */
        background: linear-gradient(
            to bottom,
            var(--fondo-pagina) 0%,
            var(--fondo-seccion) 30%,
            var(--fondo-seccion) 70%,
            var(--fondo-pagina) 100%
        );
    }

    .seccion-grid {
        display: grid;
        grid-template-columns: 1fr 2.5fr;
        gap: 4rem;
        align-items: start;
        scroll-margin-top: 100px; /* Evita que el header sticky tape el contenido */
    }

    .seccion-grid.invertida {
        grid-template-columns: 2.5fr 1fr;
    }

    .info-sticky {
        position: sticky;
        top: 100px;
    }

    .titulo-seccion {
        color: var(--seccion-titulo);
        font-size: 2.2rem;
        margin: 0 0 1rem 0;
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    .desc-seccion {
        color: var(--seccion-desc);
        font-size: 1.1rem;
        line-height: 1.6;
        margin: 0 0 1.5rem 0;
    }

    .contenedor-pildoras {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .icono-seccion {
        background: var(--borde-oscuro);
        padding: 10px;
        border-radius: 14px;
        font-size: 1.4rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .contenido-scroll {
        min-width: 0;
    }

    .grid-tarjetas {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    @media (max-width: 900px) {
        .seccion-grid,
        .seccion-grid.invertida {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .info-sticky {
            position: static;
        }

        .titulo-seccion {
            font-size: 1.8rem;
        }

        .contenedor-layout {
            padding: 2rem 1.5rem;
            gap: 4rem;
        }

        .hero-titulo {
            font-size: 2.5rem;
        }

        .seccion-grid.invertida {
            display: flex;
            flex-direction: column-reverse;
        }
    /* Estilo para ocultar tarjetas con transición */
    .tarjeta-link.hidden-card {
        display: none;
        opacity: 0;
        transform: scale(0.95);
        pointer-events: none;
    }

    /* Resaltado del botón activo */
    .filtro-btn.activo {
        border-color: var(--acento) !important;
        background-color: rgba(189, 147, 249, 0.2) !important;
        box-shadow: 0 0 15px rgba(189, 147, 249, 0.3);
    }
</style>

<script>
    function setupFilters() {
        const sections = document.querySelectorAll('.seccion-grid');

        sections.forEach(section => {
            const filterBtns = section.querySelectorAll('.filtro-btn');
            const cards = section.querySelectorAll('.tarjeta-link');

            filterBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const filter = (btn as HTMLElement).dataset.filter;

                    // Actualizar estado activo de botones en esta sección
                    filterBtns.forEach(b => b.classList.remove('activo'));
                    btn.classList.add('activo');

                    // Filtrar tarjetas
                    cards.forEach(card => {
                        const cardMateria = (card as HTMLElement).dataset.materia;
                        const cardElement = card as HTMLElement;
                        
                        if (filter === 'all' || cardMateria === filter) {
                            // Mostrar: Primero el display, luego la animación
                            cardElement.style.display = 'block';
                            // Pequeño delay para que el navegador registre el display antes de animar
                            requestAnimationFrame(() => {
                                cardElement.classList.remove('hidden-card');
                            });
                        } else {
                            // Ocultar: Instantáneo para evitar que ocupen espacio
                            cardElement.classList.add('hidden-card');
                            cardElement.style.display = 'none';
                        }
                    });
                });
            });
        });
    }

    // Ejecutar al cargar la página y en transiciones de Astro
    document.addEventListener('astro:page-load', () => {
        setupFilters();
    });

    // Carga inicial
    setupFilters();
</script>
