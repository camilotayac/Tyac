---
import Layout from "../layouts/Layout.astro";
import TarjetaCurso from "../components/TarjetaCurso.astro";
---

<Layout titulo="Tyac - Plataforma Educativa">
    <div
        style="max-width: 900px; margin: 0 auto; background: var(--card-bg); padding: 2.5rem; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); transition: background-color 0.3s ease;"
    >
        <h1 style="color: var(--title-color); font-size: 2.5rem; margin-bottom: 0.5rem; transition: color 0.3s ease;">
            Bienvenido a Tyac 🔬
        </h1>
        <p style="font-size: 1.2rem; color: var(--text-main); margin-bottom: 2rem; transition: color 0.3s ease;">
            Domina la ciencia a tu propio ritmo. Explora nuestras guías
            estructuradas.
        </p>

        <div
            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;"
        >
        <TarjetaCurso 
            titulo="Lógica Proposicional" 
            descripcion="Tablas de verdad y conectores lógicos." 
            icono="🔢" 
            categoria="matematicas"
			profesor="Camilo Tayac"
			
        />

        <TarjetaCurso 
			titulo="Dinámica Molecular" 
			descripcion="Simulación del movimiento de los átomos." 
			imagenUrl="/img/ejemplo0.png" 
			icono="⚛️" 
			categoria="quimica"
			profesor="Camilo Tayac"
		/>
        </div>
    </div>
</Layout>