---
// Importamos nuestro esqueleto y nuestras tarjetas
import Layout from "../layouts/Layout.astro";
import TarjetaCurso from "../components/TarjetaCurso.astro";
---

<Layout titulo="Tyac - Catálogo de Cursos">
    <div style="max-width: 900px; margin: 0 auto; padding: 2rem 0;">
        <h1 style="color: #2c3e50; font-size: 2.5rem;">
            Explora todos los cursos 🚀
        </h1>
        <p style="color: #666; font-size: 1.1rem; margin-bottom: 2rem;">
            Elige tu próxima ruta de aprendizaje en ciencias.
        </p>

        <div
            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;"
        >
            <TarjetaCurso
                titulo="Química Computacional"
                descripcion="Bases teóricas y herramientas in silico."
                icono="💻"
            />
            <TarjetaCurso
                titulo="Dinámica Molecular"
                descripcion="Simulaciones de trayectorias con GROMACS."
                icono="⚛️"
            />
            <TarjetaCurso
                titulo="Fisiología Vegetal"
                descripcion="Comportamiento celular a nivel biofísico."
                icono="🌱"
            />
            <TarjetaCurso
                titulo="Bioinformática Básica"
                descripcion="Análisis de secuencias y estructuras con Python."
                icono="🧬"
            />
        </div>
    </div>
</Layout>
