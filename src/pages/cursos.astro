---
import Layout from "../layouts/Layout.astro";
import TarjetaCurso from "../components/TarjetaCurso.astro";
import { todosLosTemarios } from "../data/temarios.js";

// Lista de Cursos (Materias académicas)
const cursosCiencia: any[] = [
    // La lista de cursos base está temporalmente vacía, 
    // pronto añadiremos más programas aquí.
];
---

<Layout titulo="Cursos - Tyac">
    <div style="max-width: 900px; margin: 0 auto; padding-bottom: 4rem;">
        
        <header style="margin-bottom: 3rem;">
            <h1 style="color: var(--title-color); font-size: 2.5rem; margin-bottom: 0.5rem;">
                📚 Cursos de Ciencias
            </h1>
            <p style="font-size: 1.2rem; color: var(--text-main); opacity: 0.9;">
                Explora todos los programas académicos disponibles.
            </p>
        </header>

        <section>
            {cursosCiencia.length > 0 ? (
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
                    {cursosCiencia.map((curso) => (
                        <a href={curso.href} style="text-decoration: none; color: inherit;">
                            <TarjetaCurso
                                titulo={curso.titulo}
                                descripcion={curso.descripcion}
                                icono={curso.icono}
                                categoria={curso.categoria}
                                profesor={curso.profesor}
                                nivel={curso.nivel}
                                cantidadTemas={String(curso.lecciones)}
                            />
                        </a>
                    ))}
                </div>
            ) : (
                <p style="color: var(--text-main); font-style: italic; opacity: 0.8;">
                    Por el momento se están formulando nuevos cursos de ciencias. ¡Sigue explorando los apuntes!
                </p>
            )}
        </section>

    </div>
</Layout>
