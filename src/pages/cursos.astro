---
import Layout from "../layouts/Layout.astro";
import TarjetaCurso from "../components/TarjetaCurso.astro";
import { todosCursosPlataforma } from "../data/cursos.js";
---

<Layout titulo="Tyac - Catálogo de Cursos">
    <div style="max-width: 900px; margin: 0 auto; padding: 2rem 0;">
        <h1 style="color: var(--title-color); font-size: 2.5rem;">
            Explora todos los cursos 🚀
        </h1>
        <p style="color: var(--text-main); font-size: 1.1rem; margin-bottom: 2rem;">
            Elige tu próxima ruta de aprendizaje en ciencias.
        </p>

        <div
            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;"
        >
            {todosCursosPlataforma.map((curso) => (
                curso.href ? (
                    <a href={curso.href} style="text-decoration: none; color: inherit;">
                        <TarjetaCurso
                            titulo={curso.titulo}
                            descripcion={curso.descripcion}
                            icono={curso.icono}
                            categoria={curso.categoria}
                            profesor={curso.profesor}
                            nivel={curso.nivel}
                            etiqueta={curso.etiqueta}
                        />
                    </a>
                ) : (
                    <TarjetaCurso
                        titulo={curso.titulo}
                        descripcion={curso.descripcion}
                        icono={curso.icono}
                        categoria={curso.categoria}
                        profesor={curso.profesor}
                        nivel={curso.nivel}
                        etiqueta={curso.etiqueta}
                    />
                )
            ))}
        </div>
    </div>
</Layout>
