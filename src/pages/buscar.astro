---
import Layout from '../layouts/Layout.astro';
import TarjetaCurso from '../components/TarjetaCurso.astro';
import { todosCursosPlataforma } from '../data/cursos.js';
---

<Layout titulo="Resultados de búsqueda - Tyac">
  <!-- Se elimina el <main> extra ya que Layout.astro ya incluye uno -->
  <header style="margin-bottom: 3rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem;">
    <h1 id="titulo-resultados" style="font-size: 2.5rem; color: var(--title-color); margin: 0;">
      Cargando resultados...
    </h1>
    <p id="subtitulo-resultados" style="color: var(--text-main); margin-top: 0.5rem; font-size: 1.1rem; opacity: 0.8;"></p>
  </header>

  <div id="grilla-cursos" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
    {todosCursosPlataforma.map((curso) => (
      <div
        class="tarjeta-curso"
        data-titulo={curso.titulo}
        data-desc={curso.descripcion}
        style="display: none;"
      >
        {curso.href ? (
          <a href={curso.href} style="text-decoration: none; color: inherit; display: block; height: 100%;">
            <TarjetaCurso
              titulo={curso.titulo}
              descripcion={curso.descripcion}
              icono={curso.icono}
              categoria={curso.categoria}
              profesor={curso.profesor}
              nivel={curso.nivel}
              etiqueta={curso.etiqueta}
            />
          </a>
        ) : (
          <TarjetaCurso
            titulo={curso.titulo}
            descripcion={curso.descripcion}
            icono={curso.icono}
            categoria={curso.categoria}
            profesor={curso.profesor}
            nivel={curso.nivel}
            etiqueta={curso.etiqueta}
          />
        )}
      </div>
    ))}
  </div>

  <div id="mensaje-error" style="display: none; background-color: var(--card-bg); border: 2px dashed var(--border-color); border-radius: 16px; padding: 4rem; text-align: center;">
    <span style="font-size: 4rem;">🔍</span>
    <h2 style="color: var(--title-color); margin-top: 1rem;">No encontramos lo que buscas</h2>
    <p style="color: var(--text-main); opacity: 0.8; max-width: 400px; margin: 1rem auto;">
      Intenta con palabras clave como <strong>Conjuntos</strong>, <strong>Química</strong> o <strong>Python</strong>.
    </p>
    <a href="/" style="display: inline-block; margin-top: 1.5rem; color: #3b82f6; font-weight: 600; text-decoration: none;">
      ← Volver a todos los cursos
    </a>
  </div>
</Layout>

<script is:inline>
  // 1. Leer la URL directamente desde el navegador del usuario
  const params = new URLSearchParams(window.location.search);
  const busquedaOriginal = params.get('q') || "";

  // 2. Elementos de la pantalla
  const titulo = document.getElementById('titulo-resultados');
  const subtitulo = document.getElementById('subtitulo-resultados');
  const tarjetas = document.querySelectorAll('.tarjeta-curso');
  const error = document.getElementById('mensaje-error');

  // 3. Función limpiadora (normaliza tildes y mayúsculas)
  const limpiarTexto = (texto) =>
    texto.trim().normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();

  const busquedaLimpia = limpiarTexto(busquedaOriginal);

  // 4. Actualizar el título
  if (busquedaOriginal) {
    titulo.innerHTML = `Resultados para: <span style="color: #3b82f6;">"${busquedaOriginal}"</span>`;
  } else {
    titulo.innerText = "Todos los cursos";
  }

  // 5. Filtrar las tarjetas en vivo
  let encontrados = 0;
  tarjetas.forEach(tarjeta => {
    const tituloCurso = limpiarTexto(tarjeta.getAttribute('data-titulo'));
    const descCurso = limpiarTexto(tarjeta.getAttribute('data-desc'));

    if (busquedaLimpia === "" || tituloCurso.includes(busquedaLimpia) || descCurso.includes(busquedaLimpia)) {
      tarjeta.style.display = 'block';
      encontrados++;
    } else {
      tarjeta.style.display = 'none';
    }
  });

  // 6. Mostrar mensaje según resultados
  if (encontrados > 0 && busquedaLimpia !== "") {
    subtitulo.innerText = `Hemos encontrado ${encontrados} curso(s) para tu búsqueda.`;
  } else if (encontrados === 0) {
    error.style.display = 'block';
  }
</script>