---
import Layout from '../layouts/Layout.astro';
import TarjetaCurso from '../components/TarjetaCurso.astro';

// 1. La base de datos se queda en el servidor para generar las tarjetas iniciales
const todosLosCursos = [
  { titulo: "Química Computacional", desc: "Bases teóricas e in silico.", icono: "💻" },
  { titulo: "Dinámica Molecular", desc: "Simulaciones con GROMACS.", icono: "⚛️" },
  { titulo: "Fisiología Vegetal", desc: "Biofísica de células vegetales.", icono: "🌱" },
  { titulo: "Bioinformática", desc: "Análisis de secuencias con Python.", icono: "🧬" }
];
---

<Layout titulo="Resultados de búsqueda">
  <main style="max-width: 1000px; margin: 0 auto; padding: 3rem 2rem;">
    
    <header style="margin-bottom: 3rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 1.5rem;">
      <h1 id="titulo-resultados" style="font-size: 2.5rem; color: #1e293b; margin: 0;">
        Cargando resultados...
      </h1>
      <p id="subtitulo-resultados" style="color: #64748b; margin-top: 0.5rem; font-size: 1.1rem;"></p>
    </header>

    <div id="grilla-cursos" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
      {todosLosCursos.map((curso) => (
        // Agregamos data-attributes para que JavaScript pueda leer los títulos
        <div class="tarjeta-curso" data-titulo={curso.titulo} data-desc={curso.desc} style="display: none;">
          <TarjetaCurso 
            titulo={curso.titulo} 
            descripcion={curso.desc} 
            icono={curso.icono} 
          />
        </div>
      ))}
    </div>

    <div id="mensaje-error" style="display: none; background-color: #f8fafc; border: 2px dashed #cbd5e1; border-radius: 16px; padding: 4rem; text-align: center;">
      <span style="font-size: 4rem;">🔍</span>
      <h2 style="color: #1e293b; margin-top: 1rem;">No encontramos lo que buscas</h2>
      <p style="color: #64748b; max-width: 400px; margin: 1rem auto;">
        Intenta con palabras clave como <strong>Química</strong>, <strong>Gromacs</strong> o <strong>Python</strong>.
      </p>
      <a href="/" style="display: inline-block; margin-top: 1.5rem; color: #3b82f6; font-weight: 600; text-decoration: none;">
        ← Volver a todos los cursos
      </a>
    </div>

  </main>
</Layout>

<script is:inline>
  // 1. Leer la URL directamente desde el navegador del usuario
  const params = new URLSearchParams(window.location.search);
  const busquedaOriginal = params.get('q') || "";

  // 2. Elementos de la pantalla
  const titulo = document.getElementById('titulo-resultados');
  const subtitulo = document.getElementById('subtitulo-resultados');
  const tarjetas = document.querySelectorAll('.tarjeta-curso');
  const error = document.getElementById('mensaje-error');

  // 3. Función limpiadora
  const limpiarTexto = (texto) => 
    texto.trim().normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();

  const busquedaLimpia = limpiarTexto(busquedaOriginal);

  // 4. Actualizar el título
  if (busquedaOriginal) {
    titulo.innerHTML = `Resultados para: <span style="color: #3b82f6;">"${busquedaOriginal}"</span>`;
  } else {
    titulo.innerText = "Todos los cursos";
  }

  // 5. Filtrar las tarjetas en vivo
  let encontrados = 0;
  tarjetas.forEach(tarjeta => {
    const tituloCurso = limpiarTexto(tarjeta.getAttribute('data-titulo'));
    const descCurso = limpiarTexto(tarjeta.getAttribute('data-desc'));

    // Si coincide, mostramos la tarjeta. Si no, la ocultamos.
    if (busquedaLimpia === "" || tituloCurso.includes(busquedaLimpia) || descCurso.includes(busquedaLimpia)) {
      tarjeta.style.display = 'block';
      encontrados++;
    } else {
      tarjeta.style.display = 'none';
    }
  });

  // 6. Mostrar error si no hay coincidencias
  if (encontrados > 0 && busquedaLimpia !== "") {
    subtitulo.innerText = `Hemos encontrado ${encontrados} curso(s) para tu búsqueda.`;
  } else if (encontrados === 0) {
    error.style.display = 'block';
  }
</script>