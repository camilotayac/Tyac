---
import LayoutCourses from "../../../layouts/courses/00-LayoutCourses.astro";
import TarjetaHorizontal from "../../../components/TarjetaHorizontal.astro";

const frontmatter = {
    curso: "quimica_general",
    id_clase: "atomos",
    titulo: "Estructura Atómica",
    descripcion:
        "Aprende sobre las partículas subatómicas y cómo se organiza el átomo moderno.",
    materia: "Química",
};

const videoId = "rLp_5yLhG0w"; // ID real de Khan Academy sobre Átomos
---

<LayoutCourses frontmatter={frontmatter} videoId={videoId}>
    <div slot="temario">
        <a href="/cursos/quimica_general/atomos" class="roadmap-item active">
            <div class="roadmap-diamond"><span>1</span></div>
            <div class="roadmap-info">
                <h3>Estructura Atómica</h3>
                <span class="duration">En curso</span>
            </div>
        </a>
        <a href="/cursos/quimica_general/modelos" class="roadmap-item">
            <div class="roadmap-diamond"><span>2</span></div>
            <div class="roadmap-info">
                <h3>Modelos Atómicos</h3>
                <span class="duration">15 min</span>
            </div>
        </a>
        <a href="/cursos/quimica_general/tabla" class="roadmap-item">
            <div class="roadmap-diamond"><span>3</span></div>
            <div class="roadmap-info">
                <h3>Tabla Periódica</h3>
                <span class="duration">20 min</span>
            </div>
        </a>
        <a href="/cursos/quimica_general/enlaces" class="roadmap-item">
            <div class="roadmap-diamond"><span>4</span></div>
            <div class="roadmap-info">
                <h3>Enlaces Químicos</h3>
                <span class="duration">18 min</span>
            </div>
        </a>
        <a href="/cursos/quimica_general/reacciones" class="roadmap-item">
            <div class="roadmap-diamond"><span>5</span></div>
            <div class="roadmap-info">
                <h3>Reacciones</h3>
                <span class="duration">25 min</span>
            </div>
        </a>
    </div>

    <!-- Todo lo que escribas aquí viajará automáticamente a la columna derecha del video -->

    <div class="sync-card" data-time="0">
        <h2>1. Introducción al Átomo</h2>
        <p>
            En este primer tramo, conoceremos la definición moderna y por qué es
            importante para la química moderna.
        </p>
    </div>

    <div class="sync-card" data-time="120">
        <h2>2. Partículas Subatómicas</h2>
        <p>
            Protones, Neutrones y Electrones. Descubre dónde se ubica cada uno y
            cómo sus cargas (positiva, neutra, negativa) mantienen al átomo
            estable.
        </p>
    </div>

    <div class="sync-card" data-time="240">
        <h2>3. El Núcleo Atómico</h2>
        <p>
            La zona central, pequeña pero extremadamente densa. Aquí se aloja
            casi el 99.9% de la masa total del átomo.
        </p>
    </div>

    <div class="sync-card" data-time="360">
        <h2>4. La Nube Electrónica</h2>
        <p>
            El vasto espacio vacío alrededor del núcleo donde los electrones se
            mueven a velocidades increíbles.
        </p>
    </div>

    <div class="sync-card" data-time="480">
        <h2>5. Resumen de la Clase</h2>
        <p>
            Recapitulación sobre cómo estas partículas se agrupan en nuestro
            universo conocido.
        </p>
    </div>
</LayoutCourses>
