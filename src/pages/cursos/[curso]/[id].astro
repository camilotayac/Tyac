---
// src/pages/cursos/[curso]/[id].astro
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
    const cursosEntries = await getCollection('cursos');
    return cursosEntries.map((entry: CollectionEntry<'cursos'>) => {
        return {
            params: { 
                curso: entry.data.curso, 
                id: entry.data.id_clase 
            },
            props: { entry },
        };
    });
}

import LayoutLessons from "../../../layouts/lessons/00-LayoutLessons.astro";

interface Props {
    entry: CollectionEntry<'cursos'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<LayoutLessons frontmatter={entry.data}>
    <Content />
</LayoutLessons>
