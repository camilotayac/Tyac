---
// src/pages/cursos/[id].astro
import Layout from "../../layouts/Layout.astro";
import { todosLosCursos } from "../../data/cursos.js";
import { todosLosTemarios } from "../../data/temarios.js";

export async function getStaticPaths() {
    return todosLosCursos.map((curso) => ({
        params: { id: curso.id },
        props: { curso },
    }));
}

const { id } = Astro.params;
const { curso } = Astro.props;

// Obtener el temario específico de este curso
type TemarioKey = keyof typeof todosLosTemarios;
const temarioRaw = todosLosTemarios[id as TemarioKey] || [];
---

<Layout titulo={`${curso.titulo} - Tyac`}>
    <div class="curso-landing">
        <!-- 1. HERO DEL CURSO (Efecto Spotlight) -->
        <header class="curso-hero">
            <div class="curso-hero-glow"></div>
            <div class="container container-hero">
                <div class="curso-meta">
                    <span class="badge badge-materia">{curso.materia}</span>
                    <span class="badge badge-nivel">Nivel {curso.nivel}</span>
                    <span class="badge badge-lecciones">{temarioRaw.length} clases</span>
                </div>
                <h1 class="curso-titulo">{curso.titulo}</h1>
                <p class="curso-descripcion">
                    {curso.descripcion} En este curso dominarás los conceptos fundamentales de {curso.materia} con un enfoque práctico y directo. Diseñado para que aprendas a tu ritmo y sin complicaciones.
                </p>
            </div>
        </header>

        <!-- 2. CONTENIDO PRINCIPAL (Syllabus + Sidebar) -->
        <main class="curso-grid-container">
            <div class="container grid-landing">
                <!-- Columna Izquierda: Temario (Timeline ADN Tyac) -->
                <section class="curso-syllabus">
                    <h2 class="syllabus-titulo">Temario del curso</h2>
                    <div class="timeline">
                        {temarioRaw.map((leccion, index) => (
                            <a href={`/apuntes/${id}/${leccion.id}`} class="timeline-item">
                                <div class="timeline-v-line"></div>
                                <div class="timeline-marker">
                                    <div class="diamond-box">
                                        <span>{index + 1}</span>
                                    </div>
                                </div>
                                <div class="timeline-content">
                                    <div class="leccion-bloque">
                                        <div class="leccion-info">
                                            <h3>{leccion.titulo}</h3>
                                            <span class="leccion-duracion">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                                {leccion.duracion} min
                                            </span>
                                        </div>
                                        <span class="btn-play">Ver clase &rarr;</span>
                                    </div>
                                </div>
                            </a>
                        ))}
                    </div>
                </section>

                <!-- Columna Derecha: Sidebar Sticky (CTA & Info) -->
                <aside class="curso-sidebar">
                    <div class="sticky-card">
                        <div class="card-glass">
                            <div class="video-preview-placeholder">
                                <span class="play-icon">▶</span>
                                <div class="preview-overlay"></div>
                            </div>
                            
                            <div class="card-body">
                                <div class="card-pricing">
                                    <span class="price-label">Acceso Total</span>
                                    <h3 class="price-value">Gratis y Abierto</h3>
                                </div>

                                <a href={`/apuntes/${id}/${temarioRaw[0]?.id || ""}`} class="btn-cta">
                                    Empieza ya
                                </a>

                                <ul class="curso-highlights">
                                    <li><span>✓</span> Acceso ilimitado de por vida</li>
                                    <li><span>✓</span> Contenido actualizado</li>
                                    <li><span>✓</span> Material de apoyo incluido</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </main>
    </div>
</Layout>

<style>
    .curso-landing {
        min-height: 100vh;
        background-color: var(--bg-page);
        color: var(--text-main);
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    /* --- HERO --- */
    .curso-hero {
        position: relative;
        padding: 6rem 0 4rem 0;
        overflow: hidden;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .curso-hero-glow {
        position: absolute;
        top: -20%;
        left: 50%;
        transform: translateX(-50%);
        width: 1000px;
        height: 600px;
        background: radial-gradient(circle, rgba(189, 147, 249, 0.15) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
    }

    .container-hero { position: relative; z-index: 1; }

    .curso-meta {
        display: flex;
        gap: 12px;
        margin-bottom: 1.5rem;
    }

    .badge {
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .badge-materia { background: var(--acento); color: #191a21; border: none; }
    .badge-nivel { background: rgba(255, 255, 255, 0.05); color: var(--texto-atenuado); }
    .badge-lecciones { background: rgba(255, 255, 255, 0.05); color: var(--texto-atenuado); }

    .curso-titulo {
        font-size: 3.5rem;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        color: var(--texto-claro);
    }

    .curso-descripcion {
        font-size: 1.2rem;
        color: var(--texto-atenuado);
        max-width: 800px;
        line-height: 1.6;
    }

    /* --- GRID --- */
    .curso-grid-container {
        padding: 4rem 0 10rem 0;
    }

    .grid-landing {
        display: grid;
        grid-template-columns: 1fr 350px;
        gap: 4rem;
        align-items: start;
    }

    /* --- SYLLABUS (Timeline Diamond) --- */
    .syllabus-titulo {
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 3rem;
        color: var(--texto-claro);
    }

    .timeline {
        display: flex;
        flex-direction: column;
    }

    .timeline-item {
        position: relative;
        display: flex;
        gap: 2rem;
        padding-bottom: 2rem;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s ease;
    }

    .timeline-v-line {
        position: absolute;
        left: 20px;
        top: 40px;
        bottom: 0;
        width: 2px;
        background: linear-gradient(to bottom, rgba(189, 147, 249, 0.3) 0%, transparent 100%);
        z-index: 0;
    }

    .timeline-item:last-child .timeline-v-line { display: none; }

    .timeline-marker {
        position: relative;
        z-index: 1;
        margin-top: 4px;
    }

    .diamond-box {
        width: 42px;
        height: 42px;
        background: #1e1f29;
        border: 2px solid var(--acento);
        transform: rotate(45deg);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 15px rgba(189, 147, 249, 0.2);
        transition: all 0.3s ease;
    }

    .diamond-box span {
        transform: rotate(-45deg);
        font-weight: 900;
        font-size: 1.1rem;
        color: var(--acento);
    }

    .timeline-item:hover .diamond-box {
        background: var(--acento);
        box-shadow: 0 0 25px rgba(189, 147, 249, 0.5);
    }

    .timeline-item:hover .diamond-box span {
        color: #191a21;
    }

    .timeline-content {
        flex: 1;
    }

    .leccion-bloque {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 1.5rem;
        border-radius: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.3s ease;
    }

    .timeline-item:hover .leccion-bloque {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(189, 147, 249, 0.2);
        transform: translateX(10px);
    }

    .leccion-info h3 {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: var(--texto-claro);
    }

    .leccion-duracion {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.85rem;
        color: var(--texto-atenuado);
    }

    .btn-play {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--acento);
        opacity: 0;
        transform: translateX(-10px);
        transition: all 0.3s ease;
    }

    .timeline-item:hover .btn-play {
        opacity: 1;
        transform: translateX(0);
    }

    /* --- SIDEBAR --- */
    .curso-sidebar {
        position: sticky;
        top: 100px;
    }

    .card-glass {
        background: rgba(30, 31, 41, 0.7);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
    }

    .video-preview-placeholder {
        aspect-ratio: 16/9;
        background: linear-gradient(135deg, #282a36 0%, #1e1f29 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .play-icon {
        font-size: 3rem;
        color: white;
        z-index: 2;
        filter: drop-shadow(0 0 20px rgba(189, 147, 249, 0.8));
    }

    .preview-overlay {
        position: absolute;
        inset: 0;
        background: url('https://images.unsplash.com/photo-1633356122544-f134324a6cee?auto=format&fit=crop&q=80&w=800') center/cover;
        opacity: 0.4;
        z-index: 1;
    }

    .card-body {
        padding: 2rem;
    }

    .card-pricing {
        margin-bottom: 2rem;
        text-align: center;
    }

    .price-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--texto-atenuado);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .price-value {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--texto-claro);
        margin-top: 0.5rem;
    }

    .btn-cta {
        display: block;
        width: 100%;
        padding: 1.2rem;
        background: var(--acento);
        color: #191a21;
        text-align: center;
        text-decoration: none;
        font-weight: 900;
        font-size: 1.1rem;
        border-radius: 12px;
        transition: all 0.3s ease;
        margin-bottom: 2rem;
    }

    .btn-cta:hover {
        transform: scale(1.02);
        box-shadow: 0 10px 30px rgba(189, 147, 249, 0.4);
    }

    .curso-highlights {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .curso-highlights li {
        display: flex;
        gap: 12px;
        margin-bottom: 1rem;
        font-size: 0.9rem;
        color: var(--texto-atenuado);
    }

    .curso-highlights li span {
        color: var(--dracula-green);
        font-weight: 900;
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 900px) {
        .grid-landing {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        .curso-sidebar {
            order: -1;
            position: static;
        }

        .curso-titulo {
            font-size: 2.5rem;
        }
    }
</style>
