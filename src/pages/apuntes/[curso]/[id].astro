---
// src/pages/apuntes/[curso]/[id].astro
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import LayoutLessons from '../../../layouts/lessons/00-LayoutLessons.astro';

export async function getStaticPaths() {
    const apuntesEntries = await getCollection('apuntes');
    return apuntesEntries.map((entry: CollectionEntry<'apuntes'>) => {
        return {
            params: { 
                curso: entry.data.curso, 
                id: entry.data.id_clase 
            },
            props: { entry },
        };
    });
}

interface Props {
    entry: CollectionEntry<'apuntes'>;
}

const { entry } = Astro.props;
// Astro 5 API: render() de astro:content
const { Content } = await render(entry);
---

<LayoutLessons frontmatter={entry.data}>
    <Content />
</LayoutLessons>
