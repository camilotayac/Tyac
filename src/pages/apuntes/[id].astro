---
// src/pages/apuntes/[id].astro
import LandingPageTemplate from "../../components/LandingPageTemplate.astro";
import { apuntesTecnicos } from "../../data/apuntes.js";

export async function getStaticPaths() {
    return apuntesTecnicos.map((apunte) => ({
        params: { id: apunte.id },
        props: { apunte },
    }));
}

const { apunte } = Astro.props;
---

<LandingPageTemplate curso={apunte} tipo="apunte" />
