---
// src/pages/apuntes/[id].astro
import LandingLayout from "../../layouts/landing/00-LandingLayout.astro";
import { getApuntesTecnicos } from "../../data/apuntes.js";

export async function getStaticPaths() {
    const allApuntes = await getApuntesTecnicos();
    return allApuntes.map((apunte) => ({
        params: { id: apunte.id },
        props: { apunte },
    }));
}

const { apunte } = Astro.props;
---

<LandingLayout curso={apunte} tipo="apunte" />
