---
import Layout from '../layouts/Layout.astro';
import TarjetaCurso from '../components/TarjetaCurso.astro';
import { todosCursosPlataforma } from '../data/cursos.js';
---

<Layout titulo="Temas disponibles - Tyac">
  <div style="max-width: 1000px; margin: 0 auto; padding: 2rem;">
    <h1 style="color: var(--title-color); margin-bottom: 2rem;">Explora por Temas</h1>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
      {todosCursosPlataforma.map((curso) => (
        curso.href ? (
          <a href={curso.href} style="text-decoration: none; color: inherit;">
            <TarjetaCurso
              titulo={curso.titulo}
              descripcion={curso.descripcion}
              icono={curso.icono}
              categoria={curso.categoria}
              profesor={curso.profesor}
              nivel={curso.nivel}
              etiqueta={curso.etiqueta}
            />
          </a>
        ) : (
          <TarjetaCurso
            titulo={curso.titulo}
            descripcion={curso.descripcion}
            icono={curso.icono}
            categoria={curso.categoria}
            profesor={curso.profesor}
            nivel={curso.nivel}
            etiqueta={curso.etiqueta}
          />
        )
      ))}
    </div>
  </div>
</Layout>